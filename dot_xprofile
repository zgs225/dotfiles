export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export SDL_IM_MODULE=fcitx
export GLFW_IM_MODULE=fcitx

# Kvantum Qt theme
export QT_STYLE_OVERRIDE=kvantum
export KVANTUM_THEME=catppuccin-glass

# Electron / Chromium — use Ozone GTK backend; dark mode comes from the
# freedesktop color-scheme portal (no GTK_THEME override, it would shadow
# both the GTK3 catppuccin-glass theme and GTK4 Adwaita variant selection)
export ELECTRON_OZONE_PLATFORM_HINT=auto

# Hybrid-GPU session default: force EGL onto Mesa so every GUI app's EGL path
# uses the iGPU (glvnd otherwise defaults to the NVIDIA vendor lib by filename
# order). prime-run still overrides this per-process for offload. This alone
# does NOT stop wezterm grabbing the dGPU: wezterm's WebGpu can fall back to
# NVIDIA *Vulkan* (unaffected by EGL), which the per-launch wrapper
# (dot_config/wezterm/wezterm-wrap.sh) handles by hiding the NVIDIA ICD.
export __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/50_mesa.json

systemctl --user import-environment DISPLAY PATH

/* GTK3 glassmorphism theme — matches eww popup style.
 * Managed by chezmoi; colors come from .chezmoi.yaml.tmpl data block.
 *
 * NOTE: this must live in a THEME (loaded at GTK_STYLE_PROVIDER_PRIORITY_THEME),
 * not in ~/.config/gtk-3.0/gtk.css (USER priority). USER-priority rules beat
 * everything an application sets — including all of eww's own SCSS, since eww
 * loads its CSS at APPLICATION priority — so any rule here would leak into
 * eww widgets (rounded light backgrounds on bar buttons, wifi list rows, ...).
 * At theme priority, eww's SCSS always wins and regular GTK3 apps still get
 * the glass look.
 */

@import url("resource:///org/gtk/libgtk/theme/Adwaita/gtk-contained-dark.css");

@define-color base {{ .colors.base }};
@define-color mantle {{ .colors.mantle }};
@define-color crust {{ .colors.crust }};
@define-color surface0 {{ .colors.surface0 }};
@define-color surface1 {{ .colors.surface1 }};
@define-color surface2 {{ .colors.surface2 }};
@define-color text {{ .colors.text }};
@define-color subtext1 {{ .colors.subtext1 }};
@define-color subtext0 {{ .colors.subtext0 }};
@define-color overlay0 {{ .colors.overlay0 }};
@define-color overlay1 {{ .colors.overlay1 }};
@define-color lavender {{ .colors.lavender }};
@define-color blue {{ .colors.blue }};

/* ── Menus and context menus (system tray, right-click, etc.) ── */
menu,
.context-menu,
.menu {
  background-color: alpha(@base, 0.75);
  border: 1px solid alpha(@text, 0.18);
  padding: 10px;
  border-radius: 16px;
  color: @text;
}

menuitem,
.menuitem {
  color: @subtext1;
  padding: 8px 12px;
  border-radius: 10px;
  transition: all 120ms;
}

menuitem:hover,
menuitem:selected,
.menuitem:hover,
.menuitem:selected {
  color: @text;
  background-color: alpha(@surface1, 0.40);
}

menuitem:disabled,
.menuitem:disabled {
  color: alpha(@overlay0, 0.60);
}

menu separator,
.menu separator {
  background-color: alpha(@text, 0.08);
  min-height: 1px;
  margin: 8px 4px;
}

/* ── Popovers (newer GTK3 apps replace menus with popovers) ── */
popover {
  background-color: alpha(@base, 0.75);
  border: 1px solid alpha(@text, 0.18);
  border-radius: 16px;
  padding: 10px;
  color: @text;
}

popover modelbutton {
  color: @subtext1;
  padding: 8px 12px;
  border-radius: 10px;
}

popover modelbutton:hover,
popover modelbutton:selected {
  color: @text;
  background-color: alpha(@surface1, 0.40);
}

popover separator {
  background-color: alpha(@text, 0.08);
  min-height: 1px;
  margin: 8px 4px;
}

/* ── Tooltips ── */
tooltip {
  background-color: alpha(@base, 0.92);
  border: 1px solid alpha(@text, 0.15);
  border-radius: 10px;
  padding: 6px 10px;
  color: @text;
}

/* ============================================================ MAIN APPLICATION WINDOWS ============================================================ */
/*
 * These rules apply to GTK3 system applications (file managers, settings, etc.)
 * to give them the same glassmorphism look as eww popups. They may need
 * per-app tweaks if a specific application renders badly.
 */

window,
dialog {
  background-color: alpha(@base, 0.80);
  color: @text;
}

/* Treeview / list views (file lists, settings lists) */
treeview,
treeview.view,
.view {
  background-color: alpha(@surface0, 0.55);
  color: @text;
}

treeview:selected,
treeview.view:selected,
.view:selected {
  background-color: alpha(@lavender, 0.45);
  color: @text;
}

treeview:selected:focus,
treeview.view:selected:focus,
.view:selected:focus {
  background-color: alpha(@lavender, 0.55);
  color: @text;
}

/* Sidebar / places pane */
.sidebar,
.sidebar .view,
.sidebar treeview {
  background-color: alpha(@surface0, 0.55);
  color: @text;
}

/* Notebook / tabs */
notebook {
  background-color: alpha(@surface0, 0.50);
}

notebook header {
  background-color: alpha(@surface0, 0.45);
}

notebook tab {
  background-color: alpha(@surface1, 0.30);
  color: @subtext1;
  padding: 6px 12px;
}

notebook tab:checked {
  background-color: alpha(@lavender, 0.35);
  color: @text;
}

/* Toolbars and menubars */
toolbar,
menubar {
  background-color: alpha(@surface0, 0.55);
  color: @text;
}

/* Entries / inputs */
entry {
  background-color: alpha(@surface0, 0.55);
  color: @text;
  border: 1px solid alpha(@text, 0.12);
  border-radius: 8px;
  padding: 6px 10px;
}

entry:focus {
  border-color: alpha(@lavender, 0.60);
}

/* Buttons */
button {
  background-color: alpha(@surface1, 0.40);
  color: @text;
  border: 1px solid alpha(@text, 0.12);
  border-radius: 8px;
  padding: 6px 12px;
}

button:hover {
  background-color: alpha(@surface1, 0.60);
}

button:active,
button:checked {
  background-color: alpha(@lavender, 0.40);
}

/* Scrolled windows / viewports */
scrolledwindow {
  background-color: transparent;
}

/* General separators */
separator {
  background-color: alpha(@text, 0.08);
}

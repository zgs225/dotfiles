@import "~/.config/rofi/config.rasi"

configuration {
    show-icons:      false;
    disable-history: true;
    hide-scrollbar:  true;
    sidebar-mode:    false;
}

window {
    width: @rofi-window-width;
    padding: @rofi-pad-12;
    border: 1px;
    border-color: @glass-border;
    border-radius: @rofi-bdr-radius-lg;
    background-color: @glass-bg;
}

mainbox {
    border: 0;
    padding: 0;
    children: [message, inputbar, listview];
}

message {
    background-color: @glass-inputbar;
    border: 0;
    border-left: 3px;
    border-color: @glass-accent;
    border-radius: @rofi-bdr-radius8;
    padding: @rofi-pad-8;
    margin: 0 0 6px 0;
}

textbox {
    text-color: @fg-col2;
}

inputbar {
    background-color: @glass-inputbar;
    border: 0;
    border-bottom: 2px;
    border-color: @glass-accent;
    border-radius: 8px 8px 0 0;
    padding: @rofi-pad-12;
    margin: 0 0 8px 0;
    children: [prompt, textbox-prompt-colon, entry];
    spacing: @rofi-pad-4;
}

prompt {
    padding: 0;
    text-color: @accent-col;
    font-weight: bold;
}

entry {
    padding: 0;
    placeholder: "Filter...";
    placeholder-color: @fg-col3;
    text-color: @fg-col;
}

listview {
    lines: 12;
    columns: 1;
    fixed-height: 0;
    border: 0;
    spacing: @rofi-el-spacing;
    scrollbar: false;
    padding: 0;
}

element {
    padding: @rofi-el-padding-kh;
    border: 1px;
    border-color: transparent;
    border-radius: @rofi-bdr-radius8;
    background-color: @glass-card;
    text-color: @fg-col;
    cursor: pointer;
}

element normal.normal, element alternate.normal {
    background-color: @glass-card;
    text-color: @fg-col;
    border-color: transparent;
}

element normal.active, element alternate.active {
    background-color: @glass-card-hover;
    border-color: @fg-col3;
}

element selected.normal, element selected.active {
    background-color: @glass-selected;
    text-color: @bg-col;
    border-color: @glass-accent;
}

element normal.urgent, element alternate.urgent {
    background-color: @glass-card;
    text-color: @red;
    border-color: @red;
}

element selected.urgent {
    background-color: @glass-urgent;
    text-color: @bg-col;
}

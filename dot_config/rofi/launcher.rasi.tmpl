/**
 * launcher — Catppuccin Mocha list launcher for rofi (Alfred-style)
 * Variables come from themes/palette.rasi.
 * Sizing variables come from /tmp/rofi-dpi.rasi (auto-generated by displayctl).
 */

@import "/tmp/rofi-dpi.rasi"
@import "~/.config/rofi/themes/palette.rasi"

* {
    font:               "sans-serif 18";
}

window {
    location:        center;
    width:           55%;
    padding:         @rofi-pad-16;

    border:          1px;
    border-color:    @glass-border;
    border-radius:   @rofi-bdr-radius-lg;
    background-color: @glass-bg;
}

mainbox {
    children: [inputbar, message, listview];
    spacing:  @rofi-pad-8;
}

inputbar {
    background-color: @glass-inputbar;

    border:          0;
    border-bottom:   2px;
    border-color:    @glass-accent;
    border-radius:   8px 8px 0 0;

    padding:  @rofi-pad-16;
    spacing:  @rofi-pad-8;
    children: [icon-search, prompt, entry];
}

icon-search {
    expand:        false;
    filename:      "search";
    size:          32px;
    vertical-align: 0.5;
}

icon-search, prompt, entry, element-icon, element-text {
    vertical-align: 0.5;
}

prompt {
    expand:     false;
    text-color: @accent-col;
    padding:    0px;
}

entry {
    placeholder:        "Search apps — prefixes: find, g, =, b";
    placeholder-color:  @fg-col3;
    text-color:         @fg-col;
}

message {
    padding: 0;
}

textbox {
    background-color: @glass-card;
    text-color:       @fg-col2;
    border-radius:    @rofi-bdr-radius8;
    padding:          @rofi-pad-8;
}

listview {
    lines:          10;
    columns:        1;
    fixed-columns:  true;
    fixed-height:   true;
    scrollbar:      false;
    spacing:        @rofi-pad-8;
    padding:        @rofi-pad-4;
}

element {
    padding:        @rofi-pad-12;
    spacing:        @rofi-pad-12;
    orientation:    horizontal;
    border-radius:  @rofi-bdr-radius8;
    background-color: @glass-card;
    cursor:         pointer;
}

element normal {
    background-color: @glass-card;
    text-color:       @fg-col;
    border:           1px;
    border-color:     transparent;
}

element normal.active {
    background-color: @glass-card-hover;
    border-color:     @fg-col3;
}

element selected {
    background-color: @glass-selected;
    text-color:       @bg-col;
}

element selected active {
    background-color: @glass-selected;
    text-color:       @bg-col;
}

element urgent {
    background-color: @glass-card;
    text-color:       @red;
    border-color:     @red;
}

element selected urgent {
    background-color: @glass-urgent;
    text-color:       @bg-col;
}

element-icon {
    size:              2.0em;
    horizontal-align:  0.5;
}

element-text {
    horizontal-align:  0.0;
    vertical-align:    0.5;
    text-color:        inherit;
}

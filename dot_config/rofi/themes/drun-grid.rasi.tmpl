/**
 * drun-grid — Catppuccin Mocha grid launcher for rofi
 * Variables are populated by chezmoi from .chezmoi.yaml.tmpl (data.colors).
 * Sizing variables come from /tmp/rofi-dpi.rasi (auto-generated by displayctl).
 */

* {
    /* Catppuccin Mocha palette → rofi variables */
    bg-col:        {{ .colors.base }};
    bg-col-light:  {{ .colors.surface0 }};
    bg-col-card:   {{ .colors.surface1 }};
    fg-col:        {{ .colors.text }};
    fg-col2:       {{ .colors.subtext1 }};
    fg-col3:       {{ .colors.overlay0 }};
    accent-col:    {{ .colors.mauve }};
    accent-col-2:  {{ .colors.blue }};
    red:           {{ .colors.red }};

    font:               "sans-serif 12";
    background-color:   transparent;
    text-color:         @fg-col;

    margin:     0;
    padding:    0;
    spacing:    0;
}

element-icon, element-text, scrollbar {
    cursor: pointer;
}

window {
    location:        center;
    width:           50%;
    padding:         @rofi-pad-16;

    border:          1px;
    border-color:    @bg-col-card;
    border-radius:   @rofi-bdr-radius-lg;
    background-color: @bg-col;
}

mainbox {
    children: [inputbar, listview];
    spacing:  @rofi-pad-8;
}

inputbar {
    background-color: @bg-col-light;

    border:          0;
    border-bottom:   2px;
    border-color:    @accent-col;
    border-radius:   8px 8px 0 0;

    padding:  @rofi-pad-12;
    spacing:  @rofi-pad-8;
    children: [icon-search, entry];
}

icon-search {
    expand:        false;
    filename:      "search";
    size:          24px;
    vertical-align: 0.5;
}

icon-search, entry, element-icon, element-text {
    vertical-align: 0.5;
}

entry {
    placeholder:        "Search applications...";
    placeholder-color:  @fg-col3;
    text-color:         @fg-col;
}

listview {
    lines:          4;
    columns:        5;
    fixed-columns:  true;
    fixed-height:   true;
    scrollbar:      false;
    spacing:        @rofi-pad-12;
    padding:        @rofi-pad-8;
}

element {
    padding:        @rofi-pad-12;
    spacing:        @rofi-pad-8;
    orientation:    vertical;
    border-radius:  @rofi-bdr-radius8;
    background-color: @bg-col-light;
    cursor:         pointer;
}

element normal {
    background-color: @bg-col-light;
    text-color:       @fg-col;
    border:           1px;
    border-color:     transparent;
}

element normal.active {
    background-color: @bg-col-card;
    border-color:     @fg-col3;
}

element selected {
    background-color: @accent-col;
    text-color:       @bg-col;
}

element selected active {
    background-color: @accent-col-2;
    text-color:       @bg-col;
}

element urgent {
    background-color: @bg-col-light;
    text-color:       @red;
    border-color:     @red;
}

element selected urgent {
    background-color: @red;
    text-color:       @bg-col;
}

element-icon {
    size:              3em;
    horizontal-align:  0.5;
}

element-text {
    horizontal-align:  0.5;
    text-color:        inherit;
}

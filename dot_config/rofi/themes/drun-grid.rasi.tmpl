/**
 * drun-grid — Catppuccin Mocha grid launcher for rofi
 * Variables are populated by chezmoi from .chezmoi.yaml.tmpl (data.colors).
 * Sizing variables come from /tmp/rofi-dpi.rasi (auto-generated by displayctl).
 */

* {
    /* Catppuccin Mocha palette → rofi variables */
    bg-col:        {{ .colors.base }};
    bg-col-light:  {{ .colors.surface0 }};
    bg-col-card:   {{ .colors.surface1 }};
    fg-col:        {{ .colors.text }};
    fg-col2:       {{ .colors.subtext1 }};
    fg-col3:       {{ .colors.overlay0 }};
    accent-col:    {{ .colors.mauve }};
    accent-col-2:  {{ .colors.blue }};
    red:           {{ .colors.red }};

    /* Glassmorphism — translucent variants (mirror GTK/eww Catppuccin Mocha) */
    glass-bg:           rgba( 30,  30,  46, 0.75 );
    glass-inputbar:     rgba( 49,  50,  68, 0.55 );
    glass-card:         rgba( 49,  50,  68, 0.40 );
    glass-card-hover:   rgba( 69,  71,  90, 0.52 );
    glass-card-active:  rgba( 69,  71,  90,  0.62 );
    glass-selected:     rgba(203, 166, 247, 0.55 );
    glass-selected-2:   rgba(137, 180, 250, 0.55 );
    glass-border:       rgba(205, 214, 244, 0.18 );
    glass-accent:       rgba(203, 166, 247, 0.50 );
    glass-urgent:       rgba(243, 139, 168, 0.70 );

    font:               "sans-serif 12";
    background-color:   transparent;
    text-color:         @fg-col;

    margin:     0;
    padding:    0;
    spacing:    0;
}

element-icon, element-text, scrollbar {
    cursor: pointer;
}

window {
    location:        center;
    width:           50%;
    padding:         @rofi-pad-16;

    border:          1px;
    border-color:    @glass-border;
    border-radius:   @rofi-bdr-radius-lg;
    background-color: @glass-bg;
}

mainbox {
    children: [inputbar, listview];
    spacing:  @rofi-pad-8;
}

inputbar {
    background-color: @glass-inputbar;

    border:          0;
    border-bottom:   2px;
    border-color:    @glass-accent;
    border-radius:   8px 8px 0 0;

    padding:  @rofi-pad-12;
    spacing:  @rofi-pad-8;
    children: [icon-search, entry];
}

icon-search {
    expand:        false;
    filename:      "search";
    size:          24px;
    vertical-align: 0.5;
}

icon-search, entry, element-icon, element-text {
    vertical-align: 0.5;
}

entry {
    placeholder:        "Search applications...";
    placeholder-color:  @fg-col3;
    text-color:         @fg-col;
}

listview {
    lines:          4;
    columns:        5;
    fixed-columns:  true;
    fixed-height:   true;
    scrollbar:      false;
    spacing:        @rofi-pad-12;
    padding:        @rofi-pad-8;
}

element {
    padding:        @rofi-pad-12;
    spacing:        @rofi-pad-8;
    orientation:    vertical;
    border-radius:  @rofi-bdr-radius8;
    background-color: @glass-card;
    cursor:         pointer;
}

element normal {
    background-color: @glass-card;
    text-color:       @fg-col;
    border:           1px;
    border-color:     transparent;
}

element normal.active {
    background-color: @glass-card-hover;
    border-color:     @fg-col3;
}

element selected {
    background-color: @glass-selected;
    text-color:       @bg-col;
}

element selected active {
    background-color: @glass-selected-2;
    text-color:       @bg-col;
}

element urgent {
    background-color: @glass-card;
    text-color:       @red;
    border-color:     @red;
}

element selected urgent {
    background-color: @glass-urgent;
    text-color:       @bg-col;
}

element-icon {
    size:              3em;
    horizontal-align:  0.5;
}

element-text {
    horizontal-align:  0.5;
    text-color:        inherit;
}

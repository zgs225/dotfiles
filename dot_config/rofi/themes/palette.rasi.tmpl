/**
 * palette — Song-dynasty tokens (juansha liuli) for all rofi themes.
 * Hex variables are populated by chezmoi from .chezmoi.yaml.tmpl (data.colors);
 * the rgba glass literals below are hand-tuned to the same palette (alpha
 * layers cannot be produced from hex in rasi, keep them in sync manually).
 * glass-bg follows L2 (0.65): rofi is a transient summon layer, NOT the
 * resident L1 bar — ruled 2026-07-22, do not track L1's 0.90 here.
 */

* {
    bg-col:        {{ .colors.bg_base }};
    bg-col-light:  {{ .colors.ink }};
    bg-col-card:   #3a3a44;
    fg-col:        {{ .colors.fg_primary }};
    fg-col2:       #cfccc2;
    fg-col3:       #6f6f68;
    accent-col:    {{ .colors.accent }};
    accent-col-2:  {{ .colors.accent }};
    red:           {{ .colors.error }};

    glass-bg:           rgba( 26,  26,  30, 0.65 );
    glass-inputbar:     rgba( 46,  46,  54, 0.55 );
    glass-card:         rgba( 46,  46,  54, 0.40 );
    glass-card-hover:   rgba( 58,  58,  68, 0.52 );
    glass-card-active:  rgba( 58,  58,  68, 0.62 );
    glass-selected:     rgba(158, 200, 192, 0.30 );
    glass-selected-2:   rgba(158, 200, 192, 0.30 );
    glass-border:       rgba(158, 200, 192, 0.35 );
    glass-accent:       rgba(158, 200, 192, 0.50 );
    glass-urgent:       rgba(160,  82,  45, 0.70 );

    background-color:   transparent;
    text-color:         @fg-col;

    margin:     0;
    padding:    0;
    spacing:    0;
}

element-icon, element-text, scrollbar {
    cursor: pointer;
}

configuration {
    modi: "drun,window,run";
    show-icons: true;
    icon-theme: "Papirus";
    drun-display-format: "{name}";
    matching: "normal";
    sort: true;
    terminal: "wezterm";
    sidebar-mode: false;
}

@import "/tmp/rofi-dpi.rasi"

* {
    bg-col: {{ .colors.crust }};
    bg-col-light: {{ .colors.surface0 }};
    bg-col-card: {{ .colors.base }};
    border-col: {{ .colors.blue }};
    selected-col: {{ .colors.surface1 }};
    fg-col: {{ .colors.text }};
    fg-col2: {{ .colors.subtext0 }};
    fg-col3: {{ .colors.overlay0 }};
    grey: {{ .colors.overlay0 }};
    red: {{ .colors.red }};
    urgent: {{ .colors.red }};
    green: {{ .colors.green }};
    accent-col: {{ .colors.blue }};
    yellow: {{ .colors.yellow }};

    background-color: @bg-col;
    text-color: @fg-col;
    border: 0;
    border-radius: @rofi-bdr-radius8;
    border-color: @border-col;
    padding: 0;
    spacing: 0;
}

#window {
    background-color: @bg-col;
    border: 1px solid {{ .colors.surface2 }};
    border-radius: @rofi-bdr-radius-lg;
    width: @rofi-window-width;
    padding: @rofi-pad-12;
}

#mainbox {
    border: 0;
    padding: 0;
    children: [inputbar, listview];
}

#inputbar {
    background-color: @bg-col-light;
    border: 0;
    border-bottom: 2px solid {{ .colors.blue }};
    border-radius: @rofi-bdr-radius8 @rofi-bdr-radius8 0 0;
    padding: @rofi-pad-12;
    margin: 0 0 @rofi-inputbar-margin 0;
    children: [prompt, entry];
    spacing: @rofi-pad-8;
}

#prompt {
    text-color: @accent-col;
    padding: 0;
    font-weight: bold;
}

#entry {
    padding: 0;
    placeholder: "Search...";
    placeholder-color: @fg-col3;
    text-color: @fg-col;
}

#listview {
    border: 0;
    columns: 1;
    lines: 8;
    cycle: true;
    dynamic: true;
    scrollbar: false;
    spacing: @rofi-el-spacing;
    padding: @rofi-lv-padding;
}

#element {
    padding: @rofi-pad-8 @rofi-pad-12;
    border-radius: @rofi-bdr-radius8;
    border: 0;
    spacing: @rofi-pad-8;
    cursor: pointer;
}

#element normal {
    background-color: transparent;
    text-color: @fg-col;
}

#element normal.urgent {
    background-color: transparent;
    text-color: @red;
}

#element normal.active {
    background-color: rgba(255,255,255,0.05);
    text-color: @fg-col;
}

#element selected {
    background-color: @selected-col;
    text-color: @fg-col;
    border: 1px solid {{ .colors.blue }};
}

#element selected.urgent {
    background-color: @selected-col;
    border-color: @red;
    text-color: @red;
}

#element selected.active {
    background-color: @selected-col;
    text-color: @fg-col;
}

#element alternate {
    background-color: transparent;
    text-color: @fg-col;
}

#element-icon {
    size: @rofi-icon-size;
    vertical-align: 0.5;
    padding: 0 @rofi-pad-4 0 0;
}

#element-text {
    vertical-align: 0.5;
    highlight: false;
}

#message {
    border: 0;
    padding: @rofi-pad-8;
    margin: @rofi-msg-margin 0 0 0;
    border-radius: @rofi-bdr-radius8;
    background-color: @bg-col-light;
}

#textbox {
    text-color: @fg-col2;
    padding: 0;
}

#error-message {
    text-color: @red;
    padding: @rofi-pad-8;
}

#scrollbar {
    width: @rofi-pad-4;
    border: 0;
    handle-color: @grey;
    handle-width: @rofi-pad-4;
    padding: 0;
}

#mode-switcher {
    border: 0;
    background-color: @bg-col-light;
    border-radius: @rofi-bdr-radius8;
    padding: @rofi-pad-4;
}

#button {
    background-color: transparent;
    text-color: @fg-col2;
    padding: @rofi-pad-4 @rofi-pad-8;
    border-radius: @rofi-bdr-radius4;
    border: 0;
}

#button selected {
    background-color: @selected-col;
    text-color: @accent-col;
    border: 1px solid {{ .colors.blue }};
}

#textbox-prompt-colon {
    expand: false;
    str: "";
    margin: 0;
    text-color: @accent-col;
}
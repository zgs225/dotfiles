# i3 config — juansha liuli (Song liquid glass)
# Managed by chezmoi

set $mod Mod1
set $term ~/.config/wezterm/wezterm-wrap.sh

# Font for window titles
font pango:LXGW WenKai 10

# Gaps — inner 8 aligns with eww margin system (4/8/12/16/24)
gaps inner 8
default_border pixel 2
default_floating_border pixel 2
hide_edge_borders smart

# Colors (Song mounting: tianqing hairline frame only, cinnabar reserved for ws seal)
# Inscription text tiers: yuebai > xiekeqing > xiekeqing-dark (docs/design/window-mounting.md)
#                          border   bg       text     indicator  child_border
client.focused            {{ .colors.accent }} {{ .colors.bg_base }} {{ .colors.fg_primary }}    {{ .colors.accent }}    {{ .colors.accent }}
client.focused_inactive   {{ .colors.ink }} {{ .colors.ink }} {{ .colors.fg_secondary }}    {{ .colors.ink }} {{ .colors.ink }}
client.unfocused          {{ .colors.ink }} {{ .colors.bg_base }}    #85857d    {{ .colors.ink }} {{ .colors.ink }}
client.urgent             {{ .colors.error }}      {{ .colors.error }}      {{ .colors.fg_primary }}    {{ .colors.error }}      {{ .colors.error }}
client.placeholder        {{ .colors.ink }} {{ .colors.bg_base }}    {{ .colors.fg_primary }}    {{ .colors.ink }} {{ .colors.ink }}
client.background         {{ .colors.bg_base }}

# Focus follows mouse, but mouse click doesn't change focus
focus_follows_mouse yes
focus_on_window_activation smart

# Floating modifier
floating_modifier $mod

# Workspace key bindings
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Ctrl+1 move container to workspace number 1
bindsym $mod+Ctrl+2 move container to workspace number 2
bindsym $mod+Ctrl+3 move container to workspace number 3
bindsym $mod+Ctrl+4 move container to workspace number 4
bindsym $mod+Ctrl+5 move container to workspace number 5
bindsym $mod+Ctrl+6 move container to workspace number 6
bindsym $mod+Ctrl+7 move container to workspace number 7
bindsym $mod+Ctrl+8 move container to workspace number 8
bindsym $mod+Ctrl+9 move container to workspace number 9
bindsym $mod+Ctrl+0 move container to workspace number 10

# Workspace navigation
bindsym $mod+Shift+bracketleft workspace prev
bindsym $mod+Shift+bracketright workspace next

# Layout
bindsym $mod+Shift+space floating toggle
bindsym $mod+Shift+f fullscreen toggle

# Split orientation
bindsym $mod+Ctrl+space layout toggle split

# Focus movement
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Lock screen ($mod+Ctrl+q matches macOS Cmd+Ctrl+Q)
bindsym $mod+Shift+l exec --no-startup-id ~/.config/i3/scripts/lock.sh
bindsym $mod+Ctrl+q exec --no-startup-id ~/.config/i3/scripts/lock.sh

# Focus parent/child
bindsym $mod+Ctrl+h focus parent
bindsym $mod+Ctrl+l focus child

# Move windows
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Resize mode
bindsym $mod+r mode "resize"
mode "resize" {
    # Move
    bindsym h move left 10 px
    bindsym j move down 10 px
    bindsym k move up 10 px
    bindsym l move right 10 px

    # Resize
    bindsym Shift+h resize shrink width 10 px or 10 ppt
    bindsym Shift+j resize grow height 10 px or 10 ppt
    bindsym Shift+k resize shrink height 10 px or 10 ppt
    bindsym Shift+l resize grow width 10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# Applications
bindsym $mod+Return exec $term
bindsym $mod+space exec --no-startup-id ~/.config/i3/scripts/launcher.sh
bindsym $mod+Tab exec "rofi -show window -display-window '窗口'"
bindsym $mod+Shift+v exec "rofi -modi '剪贴板:greenclip print' -show 剪贴板 -run-command '{cmd}' -theme ~/.config/rofi/clipboard.rasi"
bindsym $mod+Shift+d exec --no-startup-id dunstctl context
bindsym $mod+q kill
# Screenshots
bindsym $mod+Shift+3 exec --no-startup-id ~/.config/i3/scripts/screenshot.sh full
bindsym $mod+Shift+4 exec --no-startup-id ~/.config/i3/scripts/screenshot.sh select
# OCR — select area → copy recognized text
bindsym $mod+Shift+2 exec --no-startup-id ~/.config/i3/scripts/screenshot.sh ocr

# Keybinding helper
bindsym F1 exec --no-startup-id ~/.config/i3/scripts/keyhint

# Scratchpad
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Dropdown scratchpad
for_window [class="dropdown-.*"] \
    floating enable, \
    resize set 70 ppt 70 ppt, \
    move position center, \
    move scratchpad

bindsym $mod+backslash [class="dropdown-.*"] scratchpad show
bindsym $mod+Shift+backslash [class="dropdown-.*"] floating enable, resize set 70 ppt 70 ppt, move position center

# i3 control
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec --no-startup-id ~/.config/i3/scripts/powermenu

# Autostart
exec --no-startup-id ~/.config/i3/scripts/wallpaper.sh random
exec_always --no-startup-id ~/.config/i3/scripts/natural-scroll
{{- if and .useI3 (not .isVM) }}
exec --no-startup-id picom --config ~/.config/picom/picom.conf
{{- end }}
exec_always --no-startup-id env PATH=$HOME/.local/share/mise/shims:$PATH displayctl apply auto
exec --no-startup-id env PATH=$HOME/.local/share/mise/shims:$PATH displayctl daemon
exec_always --no-startup-id ~/.config/eww/scripts/launch.sh
exec --no-startup-id dunst
exec --no-startup-id ~/.config/i3/scripts/fprint-reminder.sh
exec --no-startup-id greenclip daemon
exec --no-startup-id fcitx5 -d
exec --no-startup-id nm-applet
exec --no-startup-id libinput-gestures-setup start
exec --no-startup-id ~/.config/eww/scripts/automount-daemon.sh
{{ if and .isLinux .useI3 }}
exec --no-startup-id keyd-application-mapper -d
{{ end }}

# Media keys — OSD
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/eww/scripts/osd.sh volume-up
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/eww/scripts/osd.sh volume-down
bindsym XF86AudioMute        exec --no-startup-id ~/.config/eww/scripts/osd.sh volume-mute
bindsym XF86AudioMicMute     exec --no-startup-id ~/.config/eww/scripts/osd.sh mic-mute
bindsym XF86MonBrightnessUp   exec --no-startup-id ~/.config/eww/scripts/osd.sh brightness-up
bindsym XF86MonBrightnessDown exec --no-startup-id ~/.config/eww/scripts/osd.sh brightness-down

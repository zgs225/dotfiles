#!/bin/sh
# i3 keybinding helper — dynamically parsed from i3 config, displayed via rofi dmenu

I3_CONFIG="$HOME/.config/i3/config"
MOD_KEY=$(sed -nre 's/^set \$mod (.*)/\1/p' "$I3_CONFIG")

grep "bindsym" "$I3_CONFIG" \
    | grep -v '^\s*#' \
    | sed -e "s/bindsym //" \
          -e 's/--no-startup-id //g' \
          -e 's/exec //' \
          -e "s/\\\$mod/${MOD_KEY}/g" \
          -e 's/Mod1/Alt/g' \
          -e 's/Mod4/Super/g' \
          -e 's/^\s\+//' \
          -e 's/  \+/ /g' \
          -e 's/^\([^ ]\+\) \(.\+\)$/\2  →  \1/' \
    | rofi -dmenu -i -p "keybindings" -theme ~/.config/rofi/keyhint.rasi

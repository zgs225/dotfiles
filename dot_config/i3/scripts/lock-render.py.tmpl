TIAN_GAN = "甲乙丙丁戊己庚辛壬癸"
DI_ZHI = "子丑寅卯辰巳午未申酉戌亥"
SHICHEN_NAMES = [
    "子时", "丑时", "寅时", "卯时", "辰时", "巳时",
    "午时", "未时", "申时", "酉时", "戌时", "亥时",
]


def hex_to_rgb(h):
    h = h.lstrip("#")
    return tuple(int(h[i:i+2], 16) / 255.0 for i in (0, 2, 4))


def _srgb_lin(c):
    return c / 12.92 if c <= 0.03928 else ((c + 0.055) / 1.055) ** 2.4


def _rel_lum(rgb):
    r, g, b = (_srgb_lin(c) for c in rgb)
    return 0.2126 * r + 0.7152 * g + 0.0722 * b


def _contrast(la, lb):
    hi, lo = (la, lb) if la >= lb else (lb, la)
    return (hi + 0.05) / (lo + 0.05)


def _region_lum(data, stride, W, H, x0, y0, x1, y1):
    x0 = max(0, int(x0))
    y0 = max(0, int(y0))
    x1 = min(W, int(x1))
    y1 = min(H, int(y1))
    total = 0.0
    n = 0
    y = y0
    while y < y1:
        row = y * stride
        x = x0
        while x < x1:
            i = row + x * 4
            b = data[i] / 255.0
            g = data[i + 1] / 255.0
            r = data[i + 2] / 255.0
            total += 0.2126 * _srgb_lin(r) + 0.7152 * _srgb_lin(g) + 0.0722 * _srgb_lin(b)
            n += 1
            x += 3
        y += 3
    return total / n if n else 0.5


def _pick(bg_lum, l_light, l_dark, rgb_light, rgb_dark):
    return rgb_light if _contrast(l_light, bg_lum) >= _contrast(l_dark, bg_lum) else rgb_dark


def shichen_index(hour):
    return (hour + 1) // 2 % 12


def shichen_name(hour):
    return SHICHEN_NAMES[shichen_index(hour)]


def jdn(year, month, day):
    a = (14 - month) // 12
    y = year + 4800 - a
    m = month + 12 * a - 3
    return day + (153 * m + 2) // 5 + 365 * y + y // 4 - y // 100 + y // 400 - 32045


def ganzhi_day(year, month, day):
    idx = (jdn(year, month, day) + 49) % 60
    return TIAN_GAN[idx % 10] + DI_ZHI[idx % 12]


def year_ganzhi(year):
    return TIAN_GAN[(year - 4) % 10] + DI_ZHI[(year - 4) % 12]


def _jd_bjt(t):
    return ((t - timedelta(hours=8)) - _EPOCH).total_seconds() / 86400.0 + 2440587.5


def _solar_lon(jd):
    T = (jd - 2451545.0) / 36525.0
    L0 = 280.46646 + 36000.76983 * T + 0.0003032 * T * T
    M = 357.52911 + 35999.05029 * T - 0.0001537 * T * T
    Mr = math.radians(M % 360)
    C = ((1.914602 - 0.004817 * T - 0.000014 * T * T) * math.sin(Mr)
         + (0.019993 - 0.000101 * T) * math.sin(2 * Mr)
         + 0.000289 * math.sin(3 * Mr))
    sun = L0 + C
    omega = 125.04 - 1934.136 * T
    return (sun - 0.00569 - 0.00478 * math.sin(math.radians(omega))) % 360


def current_jieqi(t):
    return JIEQI24[int(_solar_lon(_jd_bjt(t)) // 15)]


def luo_kuan_str(t):
    return year_ganzhi(t.year) + "年" + current_jieqi(t)


def get_screen_geometry():
    try:
        out = subprocess.check_output(
            ["xrandr", "--query"], text=True, stderr=subprocess.DEVNULL
        )
        for line in out.splitlines():
            if " connected" in line and "primary" in line:
                m = re.search(r"(\d+)x(\d+)\+", line)
                if m:
                    return int(m.group(1)), int(m.group(2))
        for line in out.splitlines():
            if " connected" in line:
                m = re.search(r"(\d+)x(\d+)\+", line)
                if m:
                    return int(m.group(1)), int(m.group(2))
    except Exception:
        pass
    return 2560, 1600


def get_wallpaper_path():
    if FEHBG.exists():
        content = FEHBG.read_text()
        m = re.search(r"--bg-\w+\s+'([^']+)'", content)
        if m:
            return Path(m.group(1))
        m = re.search(r'--bg-\w+\s+"([^"]+)"', content)
        if m:
            return Path(m.group(1))
    default = Path.home() / ".local" / "share" / "wallpapers" / "default.jpg"
    if default.exists():
        return default
    return None


def wallpaper_hash(wp_path):
    if wp_path and wp_path.exists():
        return hashlib.md5(wp_path.read_bytes()).hexdigest()[:12]
    return "solid"


def blur_wallpaper(src, width, height, dst):
    subprocess.run(
        [
            "magick", str(src),
            "-resize", f"{width}x{height}^",
            "-gravity", "center",
            "-extent", f"{width}x{height}",
            "-blur", "0x20",
            str(dst),
        ],
        check=True,
        capture_output=True,
    )


def ensure_base():
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    wp_path = get_wallpaper_path()
    h = wallpaper_hash(wp_path)
    base = CACHE_DIR / f"base-{h}.png"
    if base.exists():
        return base
    W, H = get_screen_geometry()
    tmp = CACHE_DIR / f"base-{h}.tmp.{os.getpid()}"
    try:
        if wp_path and wp_path.exists():
            blur_wallpaper(wp_path, W, H, tmp)
        else:
            subprocess.run(
                ["magick", "-size", f"{W}x{H}", "xc:#1a1a1e", str(tmp)],
                check=True, capture_output=True,
            )
        os.replace(tmp, base)
    except Exception:
        if tmp.exists():
            tmp.unlink()
        raise
    return base


def load_poems():
    if not POEMS_FILE.exists():
        return ["静夜思"]
    lines = POEMS_FILE.read_text().strip().splitlines()
    return [l.strip() for l in lines if l.strip()]


def draw_vertical_text(cr, text, cx, top_y, font_desc, step, color,
                       bg=None, color_dark=None):
    layout = PangoCairo.create_layout(cr)
    layout.set_font_description(Pango.FontDescription(font_desc))
    layout.set_alignment(Pango.Alignment.CENTER)
    adaptive = bg is not None and color_dark is not None
    if adaptive:
        data, stride, W, H = bg
        l_light = _rel_lum(color)
        l_dark = _rel_lum(color_dark)
    y = top_y
    for ch in text:
        layout.set_text(ch, -1)
        w, h = layout.get_pixel_size()
        if adaptive:
            bgL = _region_lum(data, stride, W, H,
                              cx - w / 2 - 4, y - 4, cx + w / 2 + 4, y + h + 4)
            col = _pick(bgL, l_light, l_dark, color, color_dark)
        else:
            col = color
        cr.move_to(cx - w / 2, y)
        cr.set_source_rgb(*col)
        PangoCairo.show_layout(cr, layout)
        y += step
    return y


def round_rect(cr, x, y, w, h, r):
    cr.new_sub_path()
    cr.arc(x + w - r, y + r, r, -1.5708, 0)
    cr.arc(x + w - r, y + h - r, r, 0, 1.5708)
    cr.arc(x + r, y + h - r, r, 1.5708, 3.1416)
    cr.arc(x + r, y + r, r, 3.1416, 4.7124)
    cr.close_path()


def draw_seal(cr, text, cx, top_y, font_desc, pad, bg_color, fg_color):
    gap = 2
    layouts = []
    maxw = 0
    totalh = 0
    for ch in text:
        layout = PangoCairo.create_layout(cr)
        layout.set_font_description(Pango.FontDescription(font_desc))
        layout.set_text(ch, -1)
        w, h = layout.get_pixel_size()
        layouts.append((layout, w, h))
        maxw = max(maxw, w)
        totalh += h
    totalh += gap * (len(text) - 1)

    box_w = maxw + 2 * pad
    box_h = totalh + 2 * pad
    sx = cx - box_w / 2
    sy = top_y

    round_rect(cr, sx, sy, box_w, box_h, 3)
    cr.set_source_rgb(*bg_color)
    cr.fill()

    y = sy + pad
    for layout, w, h in layouts:
        cr.move_to(sx + (box_w - w) / 2, y)
        cr.set_source_rgb(*fg_color)
        PangoCairo.show_layout(cr, layout)
        y += h + gap


def draw_shichen(cr, text, x, y, font_desc, color, bg=None, color_dark=None):
    layout = PangoCairo.create_layout(cr)
    layout.set_font_description(Pango.FontDescription(font_desc))
    layout.set_text(text, -1)
    if bg is not None and color_dark is not None:
        data, stride, W, H = bg
        w, h = layout.get_pixel_size()
        bgL = _region_lum(data, stride, W, H, x, y, x + w, y + h)
        col = _pick(bgL, _rel_lum(color), _rel_lum(color_dark), color, color_dark)
    else:
        col = color
    cr.move_to(x, y)
    cr.set_source_rgb(*col)
    PangoCairo.show_layout(cr, layout)


def build_surface(base_path, poem, sc_name, gz, luo_kuan):
    base = cairo.ImageSurface.create_from_png(str(base_path))
    W, H = base.get_width(), base.get_height()

    fg_rgb = hex_to_rgb(FG_PRIMARY)
    fg2_rgb = hex_to_rgb(FG_SECONDARY)
    seal_rgb = hex_to_rgb(SEAL_COLOR)

    surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, W, H)
    cr = cairo.Context(surface)
    cr.set_source_surface(base, 0, 0)
    cr.paint()

    bg = (bytes(surface.get_data()), surface.get_stride(), W, H)
    ink_text_rgb = hex_to_rgb(INK_TEXT)
    ink_text_dim_rgb = hex_to_rgb(INK_TEXT_DIM)

    poem_cx = int(W * 0.88)
    poem_top = int(H * 0.10)
    y_after = draw_vertical_text(
        cr, poem, poem_cx, poem_top, "Source Han Serif CN 36", 56, fg_rgb,
        bg=bg, color_dark=ink_text_rgb,
    )
    draw_seal(cr, gz, poem_cx, y_after + 40, SEAL_FONT, 8, seal_rgb, fg_rgb)

    shichen_x = int(W * 0.06)
    shichen_y = int(H * 0.82)
    draw_shichen(cr, sc_name, shichen_x, shichen_y, "Source Han Serif CN Bold 72", fg_rgb,
                 bg=bg, color_dark=ink_text_rgb)
    tmp_lay = PangoCairo.create_layout(cr)
    tmp_lay.set_font_description(Pango.FontDescription("Source Han Serif CN Bold 72"))
    tmp_lay.set_text(sc_name, -1)
    w72, _h72 = tmp_lay.get_pixel_size()
    luo_cx = shichen_x + w72 + 30
    y_luo_end = draw_vertical_text(
        cr, luo_kuan, luo_cx, shichen_y - 2,
        "LXGW WenKai 18", 26, fg2_rgb,
        bg=bg, color_dark=ink_text_dim_rgb,
    )
    draw_seal(cr, LUO_SEAL_TEXT, luo_cx, y_luo_end + 12, SEAL_FONT, 8, seal_rgb, fg_rgb)

    return surface


def write_jpeg(surface, out_path):
    W = surface.get_width()
    H = surface.get_height()
    raw = bytes(surface.get_data())
    subprocess.run(
        [
            "magick", "-size", f"{W}x{H}", "-depth", "8", "bgra:-",
            "-quality", "92", "-sampling-factor", "4:2:0", str(out_path),
        ],
        input=raw,
        check=True,
        capture_output=True,
    )


def compose_to(base_path, poem, sc_name, gz, luo_kuan, out_path):
    surface = build_surface(base_path, poem, sc_name, gz, luo_kuan)
    write_jpeg(surface, out_path)


def make_lock_image(out_path):
    base = ensure_base()
    poem = random.choice(load_poems())
    now = datetime.now()
    sc_name = shichen_name(now.hour)
    gz = ganzhi_day(now.year, now.month, now.day)
    luo_kuan = luo_kuan_str(now)
    compose_to(base, poem, sc_name, gz, luo_kuan, out_path)
    return out_path


class RenderDaemon:
    def __init__(self):
        self.poems = load_poems()
        self.last_mtime = None
        self.base_path = None

    def ensure(self):
        try:
            mt = FEHBG.stat().st_mtime
        except FileNotFoundError:
            mt = 0
        if mt != self.last_mtime or self.base_path is None:
            self.base_path = ensure_base()
            self.last_mtime = mt
        return self.base_path

    def handle(self):
        base = self.ensure()
        poem = random.choice(self.poems)
        now = datetime.now()
        sc_name = shichen_name(now.hour)
        gz = ganzhi_day(now.year, now.month, now.day)
        luo_kuan = luo_kuan_str(now)
        compose_to(base, poem, sc_name, gz, luo_kuan, COMPOSE)

    def serve(self):
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        if SOCK.exists():
            SOCK.unlink()
        srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        srv.bind(str(SOCK))
        os.chmod(str(SOCK), 0o600)
        srv.listen(8)
        print(f"lock-render daemon listening on {SOCK}", file=sys.stderr, flush=True)
        while True:
            conn, _ = srv.accept()
            with conn:
                try:
                    conn.recv(64)
                    self.handle()
                    conn.sendall(b"ok\n")
                except Exception as e:
                    try:
                        conn.sendall(b"err\n")
                    except Exception:
                        pass
                    print(f"daemon error: {e}", file=sys.stderr, flush=True)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--daemon", action="store_true",
                        help="run as a常驻 daemon serving lock-image requests over a unix socket")
    parser.add_argument("--lock-image", metavar="OUT",
                        help="synchronously compose one lock image to OUT (fallback path)")
    parser.add_argument("--ensure-base", action="store_true",
                        help="ensure blurred base exists and print its path")
    args = parser.parse_args()

    if args.daemon:
        RenderDaemon().serve()
    elif args.lock_image:
        print(make_lock_image(Path(args.lock_image)))
    else:
        print(ensure_base())


if __name__ == "__main__":
    main()

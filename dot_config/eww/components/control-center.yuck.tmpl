{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}
;; ============================================ CONTROL CENTER ============================================

(defwindow control-center [pos_x pos_y]
  :stacking "overlay"
  :windowtype "dialog"
  :focusable false
  :geometry (geometry :width "{{ $eww.controlW }}px" :height "{{ $eww.controlH }}px" :x { pos_x } :y { pos_y } :anchor "top left")
  (box :class "popup revealer control-center" :orientation "v" :spacing 0 :space-evenly false
    (box :class "popup-header" :orientation "h" :spacing 10 :valign "center" :space-evenly false
      (button :class "back-btn" :onclick "~/.config/eww/scripts/open-popup.sh control-center"
        (label :text "󰁍" :class "back-icon"))
      (label :text "控制中心" :class "popup-title" :hexpand true :xalign 0))

    ;; 2x2 toggle tiles
    (box :orientation "v" :spacing 12 :class "tile-grid"
      (box :orientation "h" :spacing 12
        (button :class "cc-tile ${wifi_on > 0 ? 'on' : ''}" :hexpand true
          :onclick "~/.config/eww/scripts/toggle-wifi.sh"
          :onrightclick "nm-connection-editor &"
          (box :orientation "h" :spacing 10 :valign "center" :space-evenly false
            (label :text "󰤨" :class "cc-tile-icon")
            (box :orientation "v" :spacing 0 :hexpand true
              (label :text "无线网" :class "cc-tile-title" :xalign 0)
              (label :text "${wifi_on > 0 ? (wifi_name == '未连接' ? '开' : wifi_name) : '关'}" :class "cc-tile-sub" :xalign 0 :limit-width 12))))
        (box :class "cc-tile ${bt_on > 0 ? 'on' : ''}" :orientation "h" :spacing 4 :valign "center" :space-evenly false :hexpand true
          (button :class "cc-tile-main" :hexpand true
            :onclick "~/.config/eww/scripts/toggle-bt.sh"
            (box :orientation "h" :spacing 10 :valign "center" :space-evenly false
              (label :text "󰂯" :class "cc-tile-icon")
              (box :orientation "v" :spacing 0
                (label :text "蓝牙" :class "cc-tile-title" :xalign 0)
                (label :text "${bt_on > 0 ? '开' : '关'}" :class "cc-tile-sub" :xalign 0))))
          (button :class "cc-tile-arrow" :valign "center" :halign "end"
            :onclick "~/.config/eww/scripts/open-popup.sh bluetooth-popup"
            (label :text "󰅂" :class "cc-tile-arrow-icon"))))
      (box :orientation "h" :spacing 12
        (button :class "cc-tile ${airplane_on > 0 ? 'on' : ''}" :hexpand true
          :onclick "~/.config/eww/scripts/toggle-airplane.sh"
          (box :orientation "h" :spacing 10 :valign "center" :space-evenly false
            (label :text "󰀝" :class "cc-tile-icon")
            (box :orientation "v" :spacing 0 :hexpand true
              (label :text "飞行模式" :class "cc-tile-title" :xalign 0 :limit-width 12)
              (label :text "${airplane_on > 0 ? '开' : '关'}" :class "cc-tile-sub" :xalign 0))))
        (button :class "cc-tile ${dnd ? 'on' : ''}" :hexpand true
          :onclick "~/.config/eww/scripts/toggle-dnd.sh"
          (box :orientation "h" :spacing 10 :valign "center" :space-evenly false
            (label :text "󰂛" :class "cc-tile-icon")
            (box :orientation "v" :spacing 0 :hexpand true
              (label :text "勿扰" :class "cc-tile-title" :xalign 0 :limit-width 13)
              (label :text "${dnd ? '开' : '关'}" :class "cc-tile-sub" :xalign 0))))))

    ;; Sliders
    (box :class "cc-slider-row" :orientation "h" :spacing 12 :valign "center" :space-evenly false
      (label :text "󰃠" :class "cc-slider-icon")
      (box :orientation "v" :spacing 3 :hexpand true
        (box :orientation "h"
          (label :text "亮度" :class "cc-slider-label" :xalign 0 :hexpand true)
          (label :text "${brightness}%" :class "cc-slider-val" :xalign 1))
        (scale :class "cc-scale" :value "${brightness}" :min 0 :max 100
          :onchange "brightnessctl set {}% >/dev/null")))
    (box :class "cc-slider-row" :orientation "h" :spacing 12 :valign "center" :space-evenly false
      (button :class "cc-slider-iconbtn" :onclick "pamixer -t"
        (label :text "${muted ? '󰝟' : (volume >= 66 ? '󰕾' : (volume >= 33 ? '󰖀' : '󰕿'))}" :class "cc-slider-icon"))
      (box :orientation "v" :spacing 3 :hexpand true
        (box :orientation "h"
          (label :text "音量" :class "cc-slider-label" :xalign 0 :hexpand true)
          (label :text "${volume}%" :class "cc-slider-val" :xalign 1))
        (scale :class "cc-scale" :value "${volume}" :min 0 :max 100
          :onchange "pamixer --set-volume {}")))

    ;; Audio device selector
    (box :class "cc-audio-devices" :orientation "v" :spacing 0
      (button :class "audio-device-header" :vexpand false
        :onclick "~/.config/eww/scripts/open-popup.sh audio-popup"
        (box :orientation "h" :spacing 10 :valign "center" :space-evenly false
          (label :text "󰋋" :class "audio-device-icon")
          (box :orientation "v" :spacing 0 :hexpand true
            (label :text "音频设备" :class "audio-device-title" :xalign 0)
            (label :text "${audio_devices.current_sink_friendly}" :class "audio-device-sub" :xalign 0 :limit-width 22))
          (label :text "󰅂" :class "audio-device-arrow"))))

    ;; Media card
    (box :class "media-card" :orientation "h" :spacing 12 :valign "center" :space-evenly false
      (box :class "media-art" :valign "center" :halign "center"
        (label :text "󰝚" :class "media-art-icon"))
      (box :orientation "v" :spacing 2 :hexpand true :valign "center"
        (label :text "${media.title}" :class "media-title" :xalign 0 :limit-width 18)
        (label :text "${media.artist}" :class "media-artist" :xalign 0 :limit-width 20))
      (box :class "media-controls" :orientation "h" :spacing 6 :valign "center"
        (button :class "media-btn" :onclick "~/.config/eww/scripts/media-ctl.sh previous"
          (label :text "󰒮" :class "media-btn-icon"))
        (button :class "media-btn play" :onclick "~/.config/eww/scripts/media-ctl.sh play-pause"
          (label :text "${media.status == 'Playing' ? '󰏤' : '󰐊'}" :class "media-btn-icon"))
        (button :class "media-btn" :onclick "~/.config/eww/scripts/media-ctl.sh next"
          (label :text "󰒭" :class "media-btn-icon"))))

    ;; Quick actions
    (box :class "cc-quick" :orientation "h" :spacing 10
      (button :class "quick-btn" :hexpand true :onclick "~/.config/eww/scripts/cc-action.sh night-light"
        (box :orientation "v" :spacing 4 :valign "center" :halign "center"
          (label :text "󰔎" :class "quick-icon") (label :text "护眼模式" :class "quick-label")))
      (button :class "quick-btn" :hexpand true :onclick "~/.config/eww/scripts/cc-action.sh screenshot"
        (box :orientation "v" :spacing 4 :valign "center" :halign "center"
          (label :text "󰹑" :class "quick-icon") (label :text "截图" :class "quick-label")))
      (button :class "quick-btn" :hexpand true :onclick "~/.config/eww/scripts/cc-action.sh performance"
        (box :orientation "v" :spacing 4 :valign "center" :halign "center"
          (label :text "󰓅" :class "quick-icon") (label :text "性能" :class "quick-label"))))))

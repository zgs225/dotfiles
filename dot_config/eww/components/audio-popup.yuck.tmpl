{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}
;; ============================================ AUDIO POPUP ============================================

(defwindow audio-popup [pos_x pos_y]
  :stacking "overlay"
  :windowtype "dialog"
  :focusable false
  :geometry (geometry :width "{{ $eww.audioW }}px" :height "{{ $eww.audioH }}px" :x { pos_x } :y { pos_y } :anchor "top left")
  (box :class "popup revealer audio-popup" :orientation "v" :spacing 0 :space-evenly false
    (box :class "popup-header" :orientation "h" :spacing 10 :valign "center" :space-evenly false
      (button :class "back-btn" :onclick "~/.config/eww/scripts/open-popup.sh control-center"
        (label :text "󰁍" :class "back-icon"))
      (label :text "音频设备" :class "popup-title" :hexpand true :xalign 0))

    (scroll :vscroll true :hscroll false :vexpand true :class "audio-scroll-wrap"
      (box :class "audio-device-list" :orientation "v" :spacing 6
        (label :text "输出设备" :class "audio-device-group-label" :xalign 0)
        (box :orientation "v" :spacing 4
          (for device in audio_sinks
            (button :class "audio-device-item ${device.active ? 'active' : ''}"
              :onclick "~/.config/eww/scripts/audio-switch.sh sink '${device.name}'"
              (box :orientation "h" :spacing 8 :valign "center" :space-evenly false
                (label :text "${device.active ? '󰄬' : '󰄰'}" :class "audio-device-check")
                (label :text "${device.friendly}" :class "audio-device-name" :xalign 0 :limit-width 26)))))
        (label :text "输入设备" :class "audio-device-group-label" :xalign 0)
        (box :orientation "v" :spacing 4
          (for device in audio_sources
            (button :class "audio-device-item ${device.active ? 'active' : ''}"
              :onclick "~/.config/eww/scripts/audio-switch.sh source '${device.name}'"
              (box :orientation "h" :spacing 8 :valign "center" :space-evenly false
                (label :text "${device.active ? '󰄬' : '󰄰'}" :class "audio-device-check")
                (label :text "${device.friendly}" :class "audio-device-name" :xalign 0 :limit-width 26)))))))))

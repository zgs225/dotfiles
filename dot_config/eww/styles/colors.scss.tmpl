/* Song-dynasty semantic tokens (juansha liuli) - canonical */
$bg-base:      {{ .colors.bg_base }};
$bg-elevated:  {{ .colors.bg_elevated }};
$ink:          {{ .colors.ink }};
$fg-primary:   {{ .colors.fg_primary }};
$fg-secondary: {{ .colors.fg_secondary }};
$accent:       {{ .colors.accent }};
$seal:         {{ .colors.seal }};
$warn:         {{ .colors.warn }};
$error:        {{ .colors.error }};

$radius:       5px;
$radius-sm:    3px;

/* Legacy aliases - mapped onto Song tokens, do not use in new code */
$rosewater: $fg-primary;
$flamingo:  #d5d0c4;
$pink:      #c9b8b3;
$mauve:     $accent;
$red:       $error;
$maroon:    #8a4526;
$peach:     #c98a4a;
$yellow:    $warn;
$green:     #8a9a6b;
$teal:      #8ab8b0;
$sky:       $accent;
$sapphire:  #7fa8a0;
$blue:      $accent;
$lavender:  $accent;
$text:      $fg-primary;
$subtext1:  #cfccc2;
$subtext0:  $fg-secondary;
$overlay2:  $fg-secondary;
$overlay1:  #85857d;
$overlay0:  #6f6f68;
$surface2:  #464652;
$surface1:  #3a3a44;
$surface0:  $ink;
$base:      $bg-base;
$mantle:    $bg-elevated;
$crust:     #15151a;

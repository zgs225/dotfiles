{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}

/* ============================================================ OSD ============================================================ */
.eww-osd { background-color: transparent; }

.osd {
  @include glass-shell(0.42, 0.20);
  border-radius: 26px;
  padding: 22px 28px;
  min-width: {{ $eww.osdW }}px;
  min-height: {{ $eww.osdH }}px;
}

.osd-icon {
  font-family: "Symbols Nerd Font";
  font-size: {{ mulf $eww.popupIconSize 2.10 | int }}px;
}
.osd-icon-blue  { color: $blue; }
.osd-icon-peach { color: $peach; }
.osd-icon-yellow{ color: $yellow; }
.osd-icon-red   { color: $red; }
.osd-icon-green { color: $green; }

.osd-title {
  color: $subtext0;
  font-size: {{ mulf $eww.popupFontSize 0.74 | int }}px;
  font-weight: bold;
  letter-spacing: 0.4px;
}

.osd-row { padding: 0; margin: 0; }

.osd-percent {
  color: $text;
  font-size: {{ mulf $eww.popupFontSize 1.20 | int }}px;
  font-weight: bold;
  min-width: 2.6em;
  transition: all 120ms ease;
}

.osd-scale trough {
  background-color: rgba($surface0, 0.55);
  border-radius: 999px;
  min-width: 130px;
  min-height: 8px;
}
.osd-scale trough highlight {
  background-color: $blue;
  border-radius: 999px;
  transition: all 120ms ease;
}
.osd-scale slider {
  background-color: transparent;
  min-width: 0; min-height: 0;
  margin: 0; padding: 0;
  border: none; box-shadow: none;
}

{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}

/* ============================================================ BAR ============================================================ */
.eww-bar { background-color: transparent; }
.bar-inner {
  background-color: rgba($bg-base, 0.90);
  border: none;
  border-top: 1px solid rgba($accent, 0.35);
  border-bottom: 1px solid rgba($accent, 0.35);
  border-radius: 0;
  margin: 0;
  min-height: {{ $eww.barHeight }}px;
  padding: 0 12px;
}

/* Module buttons */
.module-btn {
  color: $fg-secondary;
  padding: 0 6px;
  min-width: {{ $eww.cellPad }}px;
  min-height: {{ $eww.cellPad }}px;
  border-radius: $radius;
  transition: all 120ms ease;
}
.module-btn:hover { color: $fg-primary; background-color: rgba($surface1, 0.30); }
.module-icon { font-family: "Symbols Nerd Font"; font-size: {{ $eww.iconSize }}px; }
/* Leading seal (yinshou zhang): celadon hairline frame, same 32px square as ws-seal */
.app-grid {
  color: $fg-primary;
  border: 1px solid rgba($accent, 0.35);
  border-radius: 3px;
  padding: 2px 5px;
  min-width: {{ mulf $eww.fontSize 1.70 | int }}px;
  min-height: {{ mulf $eww.fontSize 1.70 | int }}px;
}
.app-grid:hover {
  color: $fg-primary;
  border-color: $accent;
  background-color: rgba($accent, 0.12);
}

/* Group separator - interpunct, faint like a ruled line on rice paper */
.bar-sep { color: rgba($fg-secondary, 0.32); font-size: {{ mulf $eww.fontSize 1.00 | int }}px; padding: 0 2px; }

/* System tray - color enclave corralled in an ink box */
.bar-tray {
  background-color: rgba($ink, 0.30);
  border-radius: 3px;
  padding: 4px;
}

/* Workspaces - cinnabar seals on Heavenly Stems */
.workspaces-container {
  padding: 1px 3px;
  min-height: {{ $eww.pillH }}px;
}
.ws-seal {
  font-family: "Chong Xi Small Seal", "LXGW WenKai", "Noto Sans CJK SC";
  /* seal-script glyphs are slim; +0.20 optical compensation keeps the 1.00 type slot */
  font-size: {{ mulf $eww.fontSize 1.20 | int }}px;
  border-radius: 3px;
  padding: 2px 5px;
  min-width: {{ mulf $eww.fontSize 1.70 | int }}px;
  min-height: {{ mulf $eww.fontSize 1.70 | int }}px;
  transition: all 180ms ease;
}
.ws-seal.active {
  background-color: $seal;
  border: 1px solid $seal;
  color: $fg-primary;
  font-weight: bold;
}
.ws-seal.occupied { border: 1px solid $accent; color: $accent; }
.ws-seal.idle     { border: 1px solid rgba($fg-secondary, 0.40); color: $fg-secondary; }
.ws-seal.urgent {
  border: 1px solid $warn;
  color: $warn;
  animation: urgent-pulse 1s ease infinite alternate;
}
@keyframes urgent-pulse { from { opacity: 1; } to { opacity: 0.4; } }

/* Battery */
.battery-pct { color: $text; font-size: {{ mulf $eww.fontSize 1.00 | int }}px; }
.bat-charging { color: $green; }
.bat-normal   { color: $subtext0; }
.bat-low      { color: $error; }

/* Time - colophon in Song serif, the only display face in the bar */
.time-main {
  font-family: "Source Han Serif CN", "Noto Serif CJK SC", serif;
  letter-spacing: 2px;
  /* GTK under-measures letter-spaced labels by ~gaps*spacing; reserve width or the colophon ellipsizes */
  min-width: {{ mulf $eww.fontSize 7.5 | int }}px;
  color: $text;
  font-weight: bold;
  font-size: {{ mulf $eww.fontSize 1.14 | int }}px;
  transition: color 120ms ease;
}
.time-btn:hover .time-main { color: lighten($text, 5%); }

/* Notification bell */
.notif-icon-wrap {
  min-width: {{ $eww.iconSize }}px;
  min-height: {{ $eww.iconSize }}px;
}
.notif-bell {
  font-family: "Symbols Nerd Font";
  font-size: {{ $eww.iconSize }}px;
}
.notif-bell-none   { color: $subtext0; }
.notif-bell-unread { color: $text; }
.notif-bell-dnd    { color: $peach; }
.notif-badge {
  background-color: $warn;
  border-radius: $radius-sm;
  min-width: 8px;
  min-height: 8px;
  margin: 0 -1px 0 0;
  border: 2px solid $bg-base;
}

{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}

/* ============================================================ NETWORK POPUP ============================================================ */
.list-row { padding: 13px 12px; border-radius: $radius; border-left: 2px solid transparent; transition: all 120ms; }
.list-row:hover { background-color: rgba($surface1, 0.40); border-left-color: $accent; }
.row-label   { color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.86 | int }}px; }
.row-icon    { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.88 | int }}px; color: $subtext0; }
.row-chevron { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.80 | int }}px; color: $overlay0; }

.wifi-network { padding: 13px 12px; border-radius: $radius; border-left: 2px solid transparent; transition: all 120ms; }
.wifi-network:hover, .wifi-network.connected { background-color: rgba($surface1, 0.36); border-left-color: $accent; }
.wifi-dot { min-width: 9px; min-height: 9px; border-radius: $radius-sm; background-color: transparent; }
.wifi-dot-on { background-color: $blue; }
.wifi-ssid   { color: $text; font-size: {{ mulf $eww.popupFontSize 0.86 | int }}px; }
.wifi-lock   { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.72 | int }}px; color: $overlay0; }
.wifi-signal { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.80 | int }}px; color: $subtext0; }
.wifi-network.connected .wifi-signal { color: $blue; }
.wifi-network.connecting { background-color: rgba($surface1, 0.36); border-left-color: $accent; }
.wifi-network.connecting .wifi-signal { color: $accent; }
.wifi-off-hint { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px; padding: 8px; }

.wired-row { padding: 13px 12px; border-radius: $radius; border-left: 2px solid transparent; transition: all 120ms; }
.wired-row:hover { background-color: rgba($surface1, 0.40); border-left-color: $accent; }
.wired-active { background-color: rgba($surface1, 0.20); }
.wired-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.88 | int }}px; color: $green; }
.wired-name { color: $text; font-size: {{ mulf $eww.popupFontSize 0.86 | int }}px; }
.wired-device { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; }
.wired-empty { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px; padding: 8px; }

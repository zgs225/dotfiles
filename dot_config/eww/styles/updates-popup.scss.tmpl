{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}

/* ============================================================ UPDATE INDICATOR ============================================================ */

.update-icon-wrap {
  min-width: {{ $eww.iconSize }}px;
  min-height: {{ $eww.iconSize }}px;
}
.update-icon { color: $subtext0; }
.update-btn.has-updates .update-icon { color: $text; }
.update-badge {
  background-color: $red;
  border-radius: 999px;
  min-width: 8px;
  min-height: 8px;
  margin: 0 -1px 0 0;
  border: 2px solid $base;
}

/* ============================================================ UPDATES POPUP ============================================================ */

.updates-popup { padding: 18px; }
.update-count-badge {
  background-color: $red;
  border-radius: 999px;
  min-width: 26px;
  padding: 3px 8px;
}
.update-count-text {
  color: white;
  font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px;
  font-weight: bold;
}
.update-last-check {
  color: $subtext0;
  font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px;
  padding: 0 0 8px 0;
}

.update-filter-row {
  padding: 0 0 10px 0;
}
.update-chip {
  @include glass-cell(0.24);
  border-radius: 10px;
  padding: 6px 12px;
  transition: all 120ms;
}
.update-chip:hover {
  background-color: rgba($surface1, 0.36);
}
.update-chip.active {
  background-color: rgba($surface1, 0.60);
}
.update-chip label {
  color: $subtext1;
  font-size: {{ mulf $eww.popupFontSize 0.80 | int }}px;
}
.update-chip.active label {
  color: $text;
  font-weight: bold;
}

.update-list-panel {
  @include glass-cell(0.24);
  border-radius: 14px;
  padding: 10px;
}
.update-list { padding: 2px; }
.update-list-item {
  padding: 7px 8px;
  border-radius: 10px;
  transition: all 120ms;
}
.update-list-item:hover { background-color: rgba($surface1, 0.36); }
.update-source-badge {
  font-family: "Symbols Nerd Font";
  font-size: {{ mulf $eww.popupFontSize 0.78 | int }}px;
  min-width: 24px;
}
.update-source-badge.official { color: $blue; }
.update-source-badge.aur { color: $mauve; }
.update-pkg-name {
  color: $text;
  font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px;
}
.update-pkg-version {
  color: $subtext0;
  font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px;
}
.update-empty-text {
  color: $overlay0;
  font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px;
  padding: 30px 0;
}
.update-actions { padding: 10px 0 0 0; }
.update-action-btn {
  @include glass-cell(0.32);
  border-radius: 12px;
  padding: 8px;
  transition: all 120ms;
}
.update-action-btn:hover { background-color: rgba($surface1, 0.48); }
.update-action-btn label {
  color: $subtext1;
  font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px;
}
.update-action-btn.disabled { opacity: 0.4; }

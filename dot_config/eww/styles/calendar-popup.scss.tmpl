{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}
{{- $calFs := mulf $eww.popupFontSize 0.86 | int -}}
{{- $calLineH := mulf $calFs 1.45 | int -}}

/* ============================================================ CALENDAR ============================================================ */
.cal {
  background-color: transparent;
  color: $subtext1;
  margin: 4px;
  font-size: {{ mulf $eww.popupFontSize 0.86 | int }}px;
}
/* Use margin, NOT padding, on the calendar widget: GtkCalendar adds the
 * element's CSS padding to EVERY day cell's height (via the "day-number"
 * style-context class) while drawing the day number at the TOP of its cell
 * and the :selected background over the WHOLE cell. Padding therefore makes
 * each row taller than the text line and the selected number rides high in
 * its pill. Margin keeps the same outer spacing without inflating cells. */
calendar {
  background-color: transparent; color: $subtext1;
}
/* Row breathing room: day-number padding inflates every cell (and thus the
 * row pitch) without touching the outer spacing. The text still anchors to
 * the cell top, so calendar:selected below clips its background back to the
 * text line (padding-bottom + content-box) to keep the number centered. */
calendar.day-number { padding: 4px 0; }
calendar:selected {
  background-color: $accent; color: $bg-base;
  padding: 0 0 8px 0;              /* must equal day-number padding top+bottom */
  background-clip: content-box;
  /* GTK shrinks border radii by the padding when clipping to the content
   * box, so a plain radius ends up asymmetric. Pre-compensate: bottom
   * corners get R+8; after the 8px shrink all corners land back on R. */
  border-radius: 3px / 3px 3px 11px 11px;
}
calendar.header { color: $fg-primary; font-weight: bold; font-size: {{ mulf $eww.popupFontSize 0.94 | int }}px; }
calendar.button { color: $subtext0; padding: 4px; }
calendar.button:hover { color: $text; }
calendar:indeterminate { color: $overlay0; }
calendar.highlight { color: $accent; font-weight: bold; }

.cal-extra { padding: 4px 0 0 0; }
.cal-col { }
.cal-col-right { min-width: {{ mulf $eww.popupFontSize 8.4 | int }}px; }
.cal-col-title { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; font-weight: bold; letter-spacing: 0.4px; }

.event-dot { min-width: 9px; min-height: 9px; border-radius: $radius-sm; margin-top: 5px; }
.event-dot-blue  { background-color: $blue; }
.event-dot-mauve { background-color: $mauve; }
.event-dot-green { background-color: $green; }
.event-dot-peach { background-color: $peach; }
.event-title { color: $text; font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px; }
.event-time  { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; }
.events-empty { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.cal-viewall { padding: 2px 0; }
.cal-viewall-label { color: $accent; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.cal-viewall:hover .cal-viewall-label { color: $fg-primary; }

.weather-box, .countdown-box {
  @include glass-cell(0.28);
  border-radius: $radius;
  padding: 12px;
}
.weather-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 1.28 | int }}px; color: $subtext0; }
.weather-temp { color: $text; font-size: {{ mulf $eww.popupFontSize 1.20 | int }}px; font-weight: bold; }
.weather-desc { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.weather-lohi { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.countdown-label { color: $text; font-size: {{ mulf $eww.popupFontSize 0.88 | int }}px; font-weight: bold; }
.countdown-sub   { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }

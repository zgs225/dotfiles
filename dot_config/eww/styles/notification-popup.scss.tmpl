{{- $eww := includeTemplate "eww-sizes" . | fromJson -}}

/* ============================================================ NOTIFICATIONS ============================================================ */
/* L4 temporary layer: lighter silk than L2 popups */
.notification-popup { background-color: rgba($bg-base, 0.60); }
.notif-scroll-wrap { min-height: 300px; }
.notif-scroll { padding: 2px; }
.notif-item {
  @include glass-cell(0.24);
  padding: 12px 10px;
  border-radius: $radius;
  border-left: 2px solid transparent;
  transition: all 120ms;
}
.notif-item:hover { background-color: rgba($surface1, 0.44); border-left-color: $accent; }
.notif-appicon {
  min-width: {{ mulf $eww.popupFontSize 2.5 | int }}px; min-height: {{ mulf $eww.popupFontSize 2.5 | int }}px; border-radius: $radius-sm;
  background-color: rgba($accent, 0.12);
  border: 1px solid rgba($accent, 0.35);
}
.notif-appicon label { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.92 | int }}px; color: $accent; }
.icon-slack    { background-color: rgba($mauve, 0.2); }
.icon-slack label { color: $mauve; }
.icon-telegram { background-color: rgba($sapphire, 0.2); }
.icon-telegram label { color: $sapphire; }
.icon-github   { background-color: rgba($surface2, 0.6); }
.icon-github label { color: $text; }
.icon-discord  { background-color: rgba($blue, 0.2); }
.icon-discord label { color: $blue; }
.icon-spotify  { background-color: rgba($green, 0.2); }
.icon-spotify label { color: $green; }
.notif-title { color: $text; font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px; font-weight: bold; }
.notif-time  { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.70 | int }}px; }
.notif-body  { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.notif-empty { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.88 | int }}px; padding: 60px 0; }

.notif-clear-all {
  color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.82 | int }}px;
  padding: 12px; margin: 12px 0 0 0;
  border-radius: $radius; background-color: rgba($surface0, 0.42);
  transition: all 120ms;
}
.notif-clear-all:hover { background-color: rgba($surface1, 0.52); color: $text; }

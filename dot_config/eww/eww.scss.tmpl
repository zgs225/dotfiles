@import "styles/colors.scss";
{{- $eww := includeTemplate "eww-sizes" . | fromJson }}

* {
  all: unset;
  font-family: "JetBrainsMono Nerd Font", "Symbols Nerd Font", "Noto Sans CJK SC";
}

@mixin glass-shell($alpha: 0.66, $border: 0.24) {
  background-color: rgba($base, $alpha);
  border: 1px solid rgba($text, $border);
  box-shadow:
    inset 0 1px 0 rgba($text, 0.20),
    inset 0 -1px 0 rgba($crust, 0.18),
    0 18px 54px rgba($crust, 0.28);
}

@mixin glass-cell($alpha: 0.30) {
  background-color: rgba($surface0, $alpha);
  border: 1px solid rgba($text, 0.12);
  box-shadow: inset 0 1px 0 rgba($text, 0.10);
}

/* ============================================================ BAR ============================================================ */
.eww-bar { background-color: transparent; }
.bar-inner {
  background-color: rgba($base, 0.72);
  border: none;
  border-bottom: 1px solid rgba($text, 0.16);
  box-shadow: 0 5px 10px -4px rgba($crust, 0.45);
  border-radius: 0;
  margin: 0;
  min-height: {{ $eww.barHeight }}px;
  padding: 0 9px;
}

/* Module buttons */
.module-btn {
  color: $subtext0;
  padding: 0 6px;
  min-width: {{ $eww.cellPad }}px;
  min-height: {{ $eww.cellPad }}px;
  border-radius: 12px;
  transition: all 120ms ease;
}
.module-btn:hover { color: $text; background-color: rgba($surface1, 0.30); }
.module-icon { font-family: "Symbols Nerd Font"; font-size: {{ $eww.iconSize }}px; }
.app-grid { color: $text; }
.app-grid:hover { color: $blue; }

/* System tray */
.bar-tray { padding: 1px 5px; }

/* Workspaces */
.workspaces-container {
  padding: 1px 3px;
  min-height: {{ $eww.pillH }}px;
}
.ws-list {
  min-height: {{ $eww.dotSize }}px;
}
.ws-dot {
  margin: {{ div (sub $eww.pillH $eww.dotSize) 2 }}px 4px 0 4px;
  min-width: {{ $eww.dotSize }}px;
  min-height: {{ $eww.dotSize }}px;
}
.ws-dot-inner {
  min-width: {{ $eww.dotSize }}px;
  min-height: {{ $eww.dotSize }}px;
  padding: 0;
  margin: 0;
  border-radius: 999px;
  transition: all 180ms ease;
}
.ws-dot-inner.idle,
.ws-dot-inner.occupied,
.ws-dot-inner.urgent {
  min-width: {{ $eww.dotSize }}px;
  min-height: {{ $eww.dotSize }}px;
  border-radius: 999px;
}
.ws-dot-inner.idle     { background-color: $surface2; }
.ws-dot-inner.occupied { background-color: $overlay1; }
.ws-dot-inner.focused  { background-color: $blue; min-width: {{ $eww.dotSize }}px; min-height: {{ $eww.dotSize }}px; border-radius: 999px; }
.ws-dot-inner.urgent   { background-color: $red; animation: urgent-pulse 1s ease infinite alternate; }
@keyframes urgent-pulse { from { opacity: 1; } to { opacity: 0.4; } }

/* Battery */
.battery-pct { color: $text; font-size: {{ mulf $eww.fontSize 0.84 | int }}px; }
.bat-charging { color: $green; }
.bat-normal   { color: $subtext0; }
.bat-low      { color: $red; }

/* Time */
.time-dow  { color: $subtext0; font-size: {{ mulf $eww.fontSize 0.62 | int }}px; }
.time-md   { color: $subtext0; font-size: {{ mulf $eww.fontSize 0.62 | int }}px; }
.time-main { color: $text; font-weight: bold; font-size: {{ mulf $eww.fontSize 1.08 | int }}px; }

/* Notification bell */
.notif-icon-wrap {
  min-width: {{ $eww.iconSize }}px;
  min-height: {{ $eww.iconSize }}px;
}
.notif-bell {
  font-family: "Symbols Nerd Font";
  font-size: {{ $eww.iconSize }}px;
}
.notif-bell-none   { color: $subtext0; }
.notif-bell-unread { color: $text; }
.notif-bell-dnd    { color: $peach; }
.notif-badge {
  background-color: $red;
  border-radius: 999px;
  min-width: 8px;
  min-height: 8px;
  margin: 0 -1px 0 0;
  border: 2px solid $base;
}

/* Invisible popup dismiss layer */
.eww-popup-scrim,
.popup-scrim-hitbox,
.popup-scrim-fill {
  background-color: transparent;
}
.popup-scrim-hitbox,
.popup-scrim-fill {
  min-width: 10000px;
  min-height: 10000px;
}

/* ============================================================ POPUP BASE ============================================================ */
.popup {
  @include glass-shell(0.50, 0.18);
  border-radius: 20px;
  padding: 22px;
  margin: 0;
}
.revealer { animation: popup-in 180ms ease; }
@keyframes popup-in { from { opacity: 0; margin-top: -4px; } to { opacity: 1; margin-top: 0; } }

.popup-header { padding: 0 0 18px 0; }
.popup-title { color: $text; font-size: {{ mulf $eww.popupFontSize 0.90 | int }}px; font-weight: bold; }
.section-label {
  color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; font-weight: bold;
  letter-spacing: 0.4px; padding: 14px 2px 8px 2px;
}
.separator-line { background-color: rgba($text, 0.08); min-height: 1px; margin: 14px 0; }

.back-btn { padding: 4px 8px 4px 0; }
.back-icon { color: $subtext0; font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.88 | int }}px; }
.back-btn:hover .back-icon { color: $text; }

.header-icon-btn { padding: 4px 8px; border-radius: 10px; transition: all 120ms; }
.header-icon-btn:hover { background-color: rgba($surface1, 0.50); }
.header-icon { color: $subtext0; font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.78 | int }}px; }

/* Toggle switch */
.header-switch { padding: 0; }
.switch {
  min-width: 46px; min-height: 26px;
  border-radius: 999px; background-color: rgba($surface2, 0.65);
  padding: 3px; transition: all 200ms ease;
}
.switch-knob {
  min-width: 20px; min-height: 20px;
  border-radius: 999px; background-color: $text;
  transition: all 200ms ease;
}
.switch.on { background-color: $blue; }
.switch.on .switch-knob { margin-left: 20px; background-color: white; }

.mini-switch {
  min-width: 38px; min-height: 22px;
  border-radius: 999px; background-color: rgba($surface2, 0.65);
  padding: 3px; transition: all 200ms ease;
}
.mini-knob {
  min-width: 16px; min-height: 16px;
  border-radius: 999px; background-color: $text;
  transition: all 200ms ease;
}
.mini-switch.on { background-color: $blue; }
.mini-switch.on .mini-knob { margin-left: 16px; background-color: white; }

/* ============================================================ PROFILE CARD ============================================================ */
.profile-header { padding: 0 0 14px 0; }
.profile-avatar {
  min-width: {{ mulf $eww.popupFontSize 3.0 | int }}px; min-height: {{ mulf $eww.popupFontSize 3.0 | int }}px;
  border-radius: 999px;
  background-color: rgba($blue, 0.20);
  border: 1px solid rgba($text, 0.10);
}
.profile-avatar-icon { color: $blue; font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 1.20 | int }}px; }
.profile-host { color: $text; font-size: {{ mulf $eww.popupFontSize 0.92 | int }}px; font-weight: bold; }
.profile-uptime { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.68 | int }}px; }

.metric-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.86 | int }}px; }
.icon-cpu  { color: $blue; }
.icon-mem  { color: $mauve; }
.icon-disk { color: $sapphire; }
.icon-temp { color: $peach; }
.metric-name { color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.74 | int }}px; }
.metric-val  { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }

.metric-bar trough {
  background-color: rgba($surface0, 0.64); border-radius: 999px;
  min-height: 6px; margin: 0;
}
.metric-bar trough highlight { border-radius: 999px; }
.metric-bar slider { background-color: transparent; min-width: 0; min-height: 0; margin: 0; padding: 0; border: none; box-shadow: none; }
.metric-bar.cpu  trough highlight { background-color: $blue; }
.metric-bar.mem  trough highlight { background-color: $mauve; }
.metric-bar.disk trough highlight { background-color: $sapphire; }
.metric-bar.temp trough highlight { background-color: $peach; }

.action-row { padding: 9px 10px; border-radius: 13px; transition: all 120ms; }
.action-row:hover { background-color: rgba($surface1, 0.40); }
.action-icon  { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.82 | int }}px; color: $subtext0; }
.action-label { color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.action-row.danger .action-icon, .action-row.danger .action-label { color: $red; }
.action-row.danger:hover { background-color: rgba($red, 0.14); }

/* ============================================================ NETWORK POPUP ============================================================ */
.list-row { padding: 12px 10px; border-radius: 13px; transition: all 120ms; }
.list-row:hover { background-color: rgba($surface1, 0.40); }
.row-label   { color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.row-icon    { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.76 | int }}px; color: $subtext0; }
.row-chevron { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.70 | int }}px; color: $overlay0; }

.wifi-network { padding: 12px 10px; border-radius: 13px; transition: all 120ms; }
.wifi-network:hover, .wifi-network.connected { background-color: rgba($surface1, 0.36); }
.wifi-dot { min-width: 8px; min-height: 8px; border-radius: 999px; background-color: transparent; }
.wifi-dot-on { background-color: $blue; }
.wifi-ssid   { color: $text; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.wifi-lock   { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.62 | int }}px; color: $overlay0; }
.wifi-signal { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.70 | int }}px; color: $subtext0; }
.wifi-network.connected .wifi-signal { color: $blue; }
.wifi-off-hint { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; padding: 8px; }

.wired-row { padding: 12px 10px; border-radius: 13px; transition: all 120ms; }
.wired-row:hover { background-color: rgba($surface1, 0.40); }
.wired-active { background-color: rgba($surface1, 0.20); }
.wired-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.76 | int }}px; color: $green; }
.wired-name { color: $text; font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px; }
.wired-device { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.62 | int }}px; }
.wired-empty { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; padding: 8px; }

/* ============================================================ CONTROL CENTER ============================================================ */
.tile-grid { padding: 0 0 6px 0; }
.cc-tile {
  @include glass-cell(0.32);
  border-radius: 15px;
  padding: 15px; transition: all 120ms;
}
.cc-tile:hover { background-color: rgba($surface1, 0.48); }
.cc-tile-icon  { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.96 | int }}px; color: $subtext0; }
.cc-tile-title { color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.74 | int }}px; font-weight: bold; }
.cc-tile-sub   { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.62 | int }}px; }
.cc-tile.on { background-color: $blue; }
.cc-tile.on .cc-tile-icon, .cc-tile.on .cc-tile-title { color: white; }
.cc-tile.on .cc-tile-sub { color: rgba(255,255,255,0.75); }

.cc-slider-row { padding: 16px 2px 6px 2px; }
.cc-slider-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.86 | int }}px; color: $subtext0; }
.cc-slider-iconbtn:hover .cc-slider-icon { color: $text; }
.cc-slider-label { color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; }
.cc-slider-val   { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }
.cc-scale trough {
  background-color: rgba($surface0, 0.62); border-radius: 999px; min-height: 7px;
}
.cc-scale trough highlight { background-color: $blue; border-radius: 999px; }
.cc-scale slider {
  background-color: white; border-radius: 999px;
  min-width: 16px; min-height: 16px; margin: -6px;
  box-shadow: 0 1px 3px rgba($crust, 0.5);
}

.media-card {
  @include glass-cell(0.34);
  border-radius: 15px;
  padding: 14px; margin: 16px 0 4px 0;
}
.media-art {
  min-width: {{ mulf $eww.popupFontSize 3.0 | int }}px; min-height: {{ mulf $eww.popupFontSize 3.0 | int }}px; border-radius: 11px;
  background-color: rgba($mauve, 0.22);
}
.media-art-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 1.04 | int }}px; color: $mauve; }
.media-title  { color: $text; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; font-weight: bold; }
.media-artist { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.62 | int }}px; }
.media-btn { padding: 6px; border-radius: 999px; transition: all 120ms; }
.media-btn:hover { background-color: rgba($surface1, 0.52); }
.media-btn-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.82 | int }}px; color: $subtext1; }
.media-btn.play .media-btn-icon { color: $text; font-size: {{ mulf $eww.popupIconSize 1.00 | int }}px; }

.cc-quick { padding: 12px 0 0 0; }
.quick-btn {
  @include glass-cell(0.30);
  border-radius: 15px;
  padding: 14px 6px; transition: all 120ms;
}
.quick-btn:hover { background-color: rgba($surface1, 0.48); }
.quick-icon  { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.94 | int }}px; color: $subtext0; }
.quick-label { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.62 | int }}px; }

/* ============================================================ CALENDAR ============================================================ */
.cal {
  background-color: transparent;
  color: $subtext1;
  padding: 4px;
  font-size: {{ mulf $eww.popupFontSize 0.76 | int }}px;
}
calendar { background-color: transparent; color: $subtext1; }
calendar:selected {
  background-color: $blue; color: white;
  border-radius: 999px;
}
calendar.header { color: $text; font-weight: bold; font-size: {{ mulf $eww.popupFontSize 0.84 | int }}px; }
calendar.button { color: $subtext0; padding: 4px; }
calendar.button:hover { color: $text; }
calendar:indeterminate { color: $overlay0; }
calendar.highlight { color: $blue; font-weight: bold; }

.cal-extra { padding: 4px 0 0 0; }
.cal-col { }
.cal-col-right { min-width: {{ mulf $eww.popupFontSize 7.8 | int }}px; }
.cal-col-title { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.62 | int }}px; font-weight: bold; letter-spacing: 0.4px; }

.event-dot { min-width: 8px; min-height: 8px; border-radius: 999px; margin-top: 5px; }
.event-dot-blue  { background-color: $blue; }
.event-dot-mauve { background-color: $mauve; }
.event-dot-green { background-color: $green; }
.event-dot-peach { background-color: $peach; }
.event-title { color: $text; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; }
.event-time  { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.62 | int }}px; }
.events-empty { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }
.cal-viewall { padding: 2px 0; }
.cal-viewall-label { color: $blue; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }
.cal-viewall:hover .cal-viewall-label { color: $sapphire; }

.weather-box, .countdown-box {
  @include glass-cell(0.28);
  border-radius: 14px;
  padding: 12px;
}
.weather-icon { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 1.16 | int }}px; color: $subtext0; }
.weather-temp { color: $text; font-size: {{ mulf $eww.popupFontSize 1.10 | int }}px; font-weight: bold; }
.weather-desc { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }
.weather-lohi { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }
.countdown-label { color: $text; font-size: {{ mulf $eww.popupFontSize 0.78 | int }}px; font-weight: bold; }
.countdown-sub   { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }

/* ============================================================ NOTIFICATIONS ============================================================ */
.notif-scroll-wrap { min-height: 300px; }
.notif-scroll { padding: 2px; }
.notif-item {
  @include glass-cell(0.24);
  padding: 12px 10px;
  border-radius: 13px;
  transition: all 120ms;
}
.notif-item:hover { background-color: rgba($surface1, 0.44); }
.notif-appicon {
  min-width: {{ mulf $eww.popupFontSize 2.28 | int }}px; min-height: {{ mulf $eww.popupFontSize 2.28 | int }}px; border-radius: 10px;
  background-color: rgba($surface0, 0.52);
}
.notif-appicon label { font-family: "Symbols Nerd Font"; font-size: {{ mulf $eww.popupIconSize 0.82 | int }}px; color: $subtext1; }
.icon-slack    { background-color: rgba($mauve, 0.2); }
.icon-slack label { color: $mauve; }
.icon-telegram { background-color: rgba($sapphire, 0.2); }
.icon-telegram label { color: $sapphire; }
.icon-github   { background-color: rgba($surface2, 0.6); }
.icon-github label { color: $text; }
.icon-discord  { background-color: rgba($blue, 0.2); }
.icon-discord label { color: $blue; }
.icon-spotify  { background-color: rgba($green, 0.2); }
.icon-spotify label { color: $green; }
.notif-title { color: $text; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px; font-weight: bold; }
.notif-time  { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.60 | int }}px; }
.notif-body  { color: $subtext0; font-size: {{ mulf $eww.popupFontSize 0.66 | int }}px; }
.notif-empty { color: $overlay0; font-size: {{ mulf $eww.popupFontSize 0.78 | int }}px; padding: 60px 0; }

.notif-clear-all {
  color: $subtext1; font-size: {{ mulf $eww.popupFontSize 0.72 | int }}px;
  padding: 12px; margin: 12px 0 0 0;
  border-radius: 13px; background-color: rgba($surface0, 0.42);
  transition: all 120ms;
}
.notif-clear-all:hover { background-color: rgba($surface1, 0.52); color: $text; }

/* ============================================================ OSD ============================================================ */
.eww-osd { background-color: transparent; }

.osd {
  @include glass-shell(0.42, 0.20);
  border-radius: 26px;
  padding: 22px 28px;
  min-width: {{ $eww.osdW }}px;
  min-height: {{ $eww.osdH }}px;
}

.osd-icon {
  font-family: "Symbols Nerd Font";
  font-size: {{ mulf $eww.popupIconSize 2.10 | int }}px;
}
.osd-icon-blue  { color: $blue; }
.osd-icon-peach { color: $peach; }
.osd-icon-yellow{ color: $yellow; }
.osd-icon-red   { color: $red; }
.osd-icon-green { color: $green; }

.osd-title {
  color: $subtext0;
  font-size: {{ mulf $eww.popupFontSize 0.74 | int }}px;
  font-weight: bold;
  letter-spacing: 0.4px;
}

.osd-row { padding: 0; margin: 0; }

.osd-percent {
  color: $text;
  font-size: {{ mulf $eww.popupFontSize 1.20 | int }}px;
  font-weight: bold;
  min-width: 2.6em;
}

.osd-scale trough {
  background-color: rgba($surface0, 0.55);
  border-radius: 999px;
  min-width: 130px;
  min-height: 8px;
}
.osd-scale trough highlight {
  background-color: $blue;
  border-radius: 999px;
}
.osd-scale slider {
  background-color: transparent;
  min-width: 0; min-height: 0;
  margin: 0; padding: 0;
  border: none; box-shadow: none;
}

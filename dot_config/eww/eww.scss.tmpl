/* HARD RULE: every SCSS file under eww/ must stay pure ASCII. grass keeps
 * loud comments and, when the compiled output contains any non-ASCII byte,
 * prepends "@charset UTF-8" which GTK3's parser rejects as "unknown @ rule"
 * -> the ENTIRE stylesheet is dropped and eww renders with zero styling.
 * (Icons belong in .yuck widgets, never in SCSS content/comments.) */
@import "styles/colors.scss";

* {
  all: unset;
  font-family: "JetBrainsMono Nerd Font", "LXGW WenKai", "Symbols Nerd Font", "Noto Sans CJK SC";
}

@import "styles/base.scss";

@import "styles/bar.scss";

@import "styles/popup-scrim.scss";

@import "styles/profile-card.scss";

@import "styles/network-popup.scss";

@import "styles/control-center.scss";

@import "styles/bluetooth-popup.scss";

@import "styles/bt-pair-dialog.scss";

@import "styles/calendar-popup.scss";

@import "styles/notification-popup.scss";

@import "styles/osd.scss";

@import "styles/updates-popup.scss";


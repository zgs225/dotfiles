#!/bin/sh
[ -z "$DISPLAYCTL_DPI" ] && exit 0
[ "$DISPLAYCTL_DPI" = "0" ] && exit 0

scale=$(echo "$DISPLAYCTL_DPI / 96" | bc -l)

# Base sizes (scaled)
font_size=$(printf "%.0f" "$(echo "12 * $scale" | bc -l)")
padding=$(printf "%.0f" "$(echo "8 * $scale" | bc -l)")
border=$(printf "%.0f" "$(echo "2 * $scale" | bc -l)")
icon_size=$(printf "%.1f" "$(echo "1.333 * $scale" | bc -l)")
window_width=$(printf "%.0f" "$(echo "25 * $scale" | bc -l)")
window_md=$(printf "%.0f" "$(echo "18 * $scale" | bc -l)")

# Dynamic fallback for small screens
[ "$window_width" -lt 35 ] && window_width=35
[ "$window_md" -lt 25 ] && window_md=25

cat > /tmp/rofi-dpi.rasi << EOF
// Auto-generated by displayctl — do not edit
* {
    // Base sizes (scaled by DPI)
    rofi-padding: ${padding}px;
    rofi-border: ${border}px;
    rofi-font-size: ${font_size}px;
    rofi-icon-size: ${icon_size}em;
    rofi-window-width: ${window_width}%;
    rofi-win-md: ${window_md}%;

    // Border radius (fixed, Song restraint: 3-6px)
    rofi-bdr-radius4: 3px;
    rofi-bdr-radius8: 5px;
    rofi-bdr-radius-lg: 5px;

    // Spacing system (fixed)
    rofi-pad-4: 4px;
    rofi-pad-8: 8px;
    rofi-pad-12: 12px;
    rofi-pad-16: 16px;

    // Component margins
    rofi-inputbar-margin: 8px;
    rofi-msg-margin: 6px;
    rofi-el-spacing: 4px;
    rofi-lv-padding: 8px;

    // Element padding
    rofi-el-padding-pm: 14px 20px;
    rofi-el-padding-kh: 10px 16px;
}
EOF

[global]
font = LXGW WenKai 10
markup = yes
format = "<b>%s</b>\n%b"
sort = yes
indicate_hidden = yes
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
idle_threshold = 120
monitor = 0
follow = mouse
sticky_history = yes
history_length = 20
show_indicators = no
line_height = 0
separator_height = 2
padding = 10
horizontal_padding = 12
separator_color = frame
browser = firefox
dmenu = rofi -dmenu -p dunst
icon_position = left
max_icon_size = 28
icon_corner_radius = 3
icon_corners = all
frame_width = 1
frame_color = "{{ .colors.accent }}59"
width = 300
height = (0, 300)
origin = top-right
offset = (12, 12)
notification_limit = 5
corner_radius = 5
corners = all
gap_size = 8
transparency = 0

[urgency_low]
background = "{{ .colors.bg_base }}99"
foreground = "{{ .colors.fg_primary }}"
frame_color = "{{ .colors.accent }}40"
timeout = 5

[urgency_normal]
background = "{{ .colors.bg_base }}99"
foreground = "{{ .colors.fg_primary }}"
frame_color = "{{ .colors.accent }}59"
timeout = 5

[urgency_critical]
background = "{{ .colors.bg_base }}E6"
foreground = "{{ .colors.fg_primary }}"
frame_color = "{{ .colors.error }}"
timeout = 0

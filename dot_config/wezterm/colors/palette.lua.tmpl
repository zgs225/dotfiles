{{ if and .isLinux .useI3 }}
-- Song Ink palette ("juansha liuli") for the WezTerm side of the terminal
-- unification (docs/design/terminal-unification.md). Values come from chezmoi
-- data.colors tokens and the registered derived fixed values in
-- docs/design/song-liquid-glass.md S2.1 -- no invented colors.
-- Consumed by WezTerm via custom.lua; tmux colors render directly from
-- dot_tmux.conf.local.tmpl (the old sync script is gone).

local palette = {
   background = '{{ .colors.bg_base }}', -- xuan (ink black)
   foreground = '{{ .colors.fg_primary }}', -- yuebai (moon white)
   black = '#15151a', -- crust: xuan dark rank (derived)
   red = '{{ .colors.error }}', -- zheshi (ochre); cinnabar stays seal-only
   green = '#8a9a6b', -- tai lv (moss): registered ANSI green (derived)
   yellow = '{{ .colors.warn }}', -- tenghuang (gamboge)
   blue = '{{ .colors.accent }}', -- tianqing (Ru-ware): blue-purple is forbidden
   magenta = '#c9b8b3', -- zhefen: registered ANSI magenta (derived)
   cyan = '#7fa8a0', -- deep tianqing: registered ANSI cyan (derived)
   white = '#cfccc2', -- yuebai second rank (derived)
   bright_black = '#6f6f68', -- xieqing dark rank (derived)
   bright_red = '{{ .colors.error }}',
   bright_green = '#8a9a6b',
   bright_yellow = '{{ .colors.warn }}',
   bright_blue = '{{ .colors.accent }}',
   bright_magenta = '#c9b8b3',
   bright_cyan = '#7fa8a0',
   bright_white = '{{ .colors.fg_primary }}',
}

palette.ansi = {
   palette.black,
   palette.red,
   palette.green,
   palette.yellow,
   palette.blue,
   palette.magenta,
   palette.cyan,
   palette.white,
}

palette.brights = {
   palette.bright_black,
   palette.bright_red,
   palette.bright_green,
   palette.bright_yellow,
   palette.bright_blue,
   palette.bright_magenta,
   palette.bright_cyan,
   palette.bright_white,
}

palette.chrome = {
   cursor_bg = '{{ .colors.fg_primary }}',
   cursor_fg = '{{ .colors.bg_base }}',
   cursor_border = '{{ .colors.fg_primary }}',
   selection_bg = '{{ .colors.ink }}',
   selection_fg = '{{ .colors.fg_primary }}',
   split = '#464652', -- ink bright rank (derived)
}

palette.tab_title = {
   default = { bg = '{{ .colors.ink }}', fg = '{{ .colors.fg_secondary }}' },
   is_active = { bg = '{{ .colors.accent }}', fg = '{{ .colors.bg_base }}' },
   hover = { bg = '#464652', fg = '{{ .colors.fg_primary }}' },
   unseen_fg = '{{ .colors.warn }}',
}

palette.left_status = {
   glyph_semi_circle = { bg = 'rgba(0, 0, 0, 0.4)', fg = '{{ .colors.warn }}' },
   text = { bg = '{{ .colors.warn }}', fg = '{{ .colors.bg_base }}' },
}

-- Mapping from palette keys -> tmux_conf_theme_colour_N semantics.
-- colour_1  = main background (status bar, window status background)
-- colour_2  = pane border, focused pane background
-- colour_3  = status bar text, window status text
-- colour_4  = active pane border, highlights, left-status background
-- colour_5  = message/mode background, bell foreground (yellow)
-- colour_6  = status-left content foreground
-- colour_7  = light text
-- colour_8  = dark background (status-left secondary)
-- colour_9  = mode pane border background, status-left primary background (yellow)
-- colour_10 = purple accent (status-left background)
-- colour_11 = green accent
-- colour_12 = status-right foreground (light gray)
-- colour_13 = white text
-- colour_14 = status-right background base
-- colour_15 = status-right background base
-- colour_16 = window-current foreground (red)
-- colour_17 = status-right background highlight
local tmux_mapping = {
   colour_1 = 'background',
   colour_2 = 'bright_black',
   colour_3 = 'white',
   colour_4 = 'blue',
   colour_5 = 'yellow',
   colour_6 = 'foreground',
   colour_7 = 'foreground',
   colour_8 = 'background',
   colour_9 = 'yellow',
   colour_10 = 'magenta',
   colour_11 = 'green',
   colour_12 = 'white',
   colour_13 = 'foreground',
   colour_14 = 'background',
   colour_15 = 'background',
   colour_16 = 'red',
   colour_17 = 'bright_white',
}

return {
   palette = palette,
   tmux_mapping = tmux_mapping,
}

   red = '#f7768e',
   green = '#9ece6a',
   yellow = '#e0af68',
   blue = '#7aa2f7',
   magenta = '#bb9af7',
   cyan = '#7dcfff',
   white = '#a9b1d6',
   bright_black = '#414868',
   bright_red = '#f7768e',
   bright_green = '#9ece6a',
   bright_yellow = '#e0af68',

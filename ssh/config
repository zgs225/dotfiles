Include conf.d/*

Host jp1
    HostName jp1.yuez.me
    Port 28888
    User ubuntu
    IdentityFile ~/.ssh/LightsailDefaultKey-ap-southeast-1.pem
    ForwardAgent yes

Host bj2
    Hostname bj2.yuez.me
    User yuez
    ForwardAgent yes

Host la1
    HostName la1.yuez.me
    User root
    ForwardAgent yes

Host router
    User root
    HostName 192.168.2.1

Host router-proxy
    User root
    HostName 192.168.2.1
    ProxyJump bj2

Host pve
    User root
    HostName 192.168.2.254

Host pve-253
    User root
    HostName 192.168.2.253

Host clawbuntu
    User yuez
    HostName 192.168.2.16
    ProxyJump bj2

Host dsm
    User yuez
    HostName 192.168.2.183
    SetEnv TERM=xterm-256color

Host pi-hole
    User root
    HostName 192.168.2.3

Host *
    StrictHostKeyChecking no
    ServerAliveInterval 10
    PubkeyAcceptedAlgorithms +ssh-rsa
    HostkeyAlgorithms +ssh-rsa

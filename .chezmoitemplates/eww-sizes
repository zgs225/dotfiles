{{- /* Eww bar DPI tier detected at apply time, emitted as JSON.
       eww 0.5.0 cannot resolve variables in a window :geometry and GTK does not
       reliably size empty boxes from runtime CSS variables, so every size is
       baked as a literal and shared by eww.yuck.tmpl and eww.scss.tmpl. */ -}}
{{- $dpi := 0 -}}
{{- if lookPath "xrdb" -}}
{{-   $out := output "sh" "-c" "xrdb -query 2>/dev/null | awk '/Xft.dpi/ {print $2}' | head -1 | cut -d. -f1" | trim -}}
{{-   if $out }}{{ $dpi = atoi $out }}{{ end -}}
{{- end -}}
